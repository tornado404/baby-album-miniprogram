# 宝宝成长相册 API 服务
# 环境变量模板 — 复制为 .env 后填写实际值

# 应用
APP_NAME=宝宝成长相册 API
DEBUG=true

# 数据库（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://app:change_me@localhost:5432/baby_album

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-your-256-bit-secret
JWT_REFRESH_SECRET=change-this-to-your-refresh-secret

# 微信小程序
WECHAT_APP_ID=wx3db22b5d6da5d38a
WECHAT_APP_SECRET=your-wechat-app-secret

# 腾讯云 COS（或阿里云 OSS）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=baby-album
COS_REGION=ap-guangzhou

# 存储路径前缀
COS_PHOTO_PATH=photos
COS_THUMB_PATH=thumbnails
COS_AVATAR_PATH=avatars

# 上传限制
UPLOAD_MAX_SIZE=20971520

# 缩略图
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300
THUMBNAIL_QUALITY=80

# 限流
RATE_LIMIT_PER_MINUTE=100
# MinIO 对象存储（独立容器）
MINIO_ENDPOINT=101.126.41.146:9000
MINIO_ACCESS_KEY=Cs516@2026
MINIO_SECRET_KEY=Cs516@2026
MINIO_BUCKET=baby-album
MINIO_PUBLIC_URL=http://101.126.41.146:9000
