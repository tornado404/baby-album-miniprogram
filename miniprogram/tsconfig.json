{
  "compilerOptions": {
    "target": "ES5",
    "module": "CommonJS",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "lib": ["ES2017", "DOM"],
    "ignoreDeprecations": "6.0",
    "noEmitOnError": false,
    "types": []
  },
  "include": [
    "./pages/**/*.ts",
    "./components/**/*.ts",
    "./services/**/*.ts",
    "./utils/**/*.ts",
    "./app.ts",
    "../typings/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "miniprogram_npm",
    "tests",
    "scripts"
  ]
}
