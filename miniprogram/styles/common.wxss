/**
 * 公共样式
 * 全局可复用的样式类和 mixins
 */

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.ellipsis-3 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* 清除浮动 */
.clearfix::after {
  content: '';
  display: table;
  clear: both;
}

/* 文本对齐 */
.text-left {
  text-align: left;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

/* 文字单双行省略（兼容小程序）*/
.single-ellipsis {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.multi-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
}

/* Flex 布局工具类 */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-around {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.flex-shrink-0 {
  flex-shrink: 0;
}

/* 内外边距 */
.mt-sm { margin-top: var(--spacing-xs); }
.mt-md { margin-top: var(--spacing-sm); }
.mt-lg { margin-top: var(--spacing-md); }

.mb-sm { margin-bottom: var(--spacing-xs); }
.mb-md { margin-bottom: var(--spacing-sm); }
.mb-lg { margin-bottom: var(--spacing-md); }

.ml-sm { margin-left: var(--spacing-xs); }
.ml-md { margin-left: var(--spacing-sm); }
.ml-lg { margin-left: var(--spacing-md); }

.mr-sm { margin-right: var(--spacing-xs); }
.mr-md { margin-right: var(--spacing-sm); }
.mr-lg { margin-right: var(--spacing-md); }

.pt-sm { padding-top: var(--spacing-xs); }
.pt-md { padding-top: var(--spacing-sm); }
.pt-lg { padding-top: var(--spacing-md); }

.pb-sm { padding-bottom: var(--spacing-xs); }
.pb-md { padding-bottom: var(--spacing-sm); }
.pb-lg { padding-bottom: var(--spacing-md); }

/* 1px 边框 */
.hairline-top {
  border-top: 1rpx solid var(--border-color);
}

.hairline-bottom {
  border-bottom: 1rpx solid var(--border-color);
}

.hairline-left {
  border-left: 1rpx solid var(--border-color);
}

.hairline-right {
  border-right: 1rpx solid var(--border-color);
}

/* 卡片样式 */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.card + .card {
  margin-top: var(--spacing-md);
}
