/**
 * Claymorphism 主题样式变量
 * 设计来源: Figma - 宝宝成长日记 Claymorphism UI
 * 暖色调、柔和阴影、大圆角
 */

/* 主题颜色 */
page {
  /* Claymorphism 主色调 */
  --clay-bg: #fffbf8;
  --clay-primary: #ffa87a;
  --clay-primary-shadow: rgba(255, 168, 122, 0.35);
  --clay-primary-shadow-heavy: rgba(255, 168, 122, 0.4);

  /* 文字颜色 */
  --clay-text-primary: #4a4a4a;
  --clay-text-secondary: #999999;
  --clay-text-light: #808080;
  --clay-text-muted: #b3b3b3;
  --clay-text-accent: #806680;
  --clay-text-warm: #998066;
  --clay-text-pink: #806666;
  --clay-text-dark-warm: #665959;

  /* 卡片背景色 */
  --clay-card-pink: #f1dce2;
  --clay-card-blue: #dceaf1;
  --clay-card-beige: #f4e6d6;
  --clay-card-mint: #e2f1e6;
  --clay-card-white: #ffffff;

  /* UI 元素色 */
  --clay-icon-bg: #f9f0e9;
  --clay-avatar-lavender: #ddd6ea;
  --clay-white-overlay: rgba(255, 255, 255, 0.5);
  --clay-stat-dot-pink: #f1dce2;
  --clay-stat-dot-blue: #dceaf1;
  --clay-stat-dot-lavender: #ddd6ea;

  /* 阴影 - 通用 */
  --clay-shadow-card: 0px 6px 16px 0px rgba(230, 198, 179, 0.35);
  --clay-shadow-card-light: 0px 3px 8px 0px rgba(230, 198, 179, 0.18);
  --clay-shadow-card-lighter: 0px 2px 4px 0px rgba(230, 198, 179, 0.2);
  --clay-shadow-card-soft: 0px 6px 20px 0px rgba(230, 198, 179, 0.25);
  --clay-shadow-nav: 0px -3px 10px 0px rgba(230, 198, 179, 0.15);

  /* 阴影 - 彩色卡片 */
  --clay-shadow-pink: 0px 5px 12px 0px rgba(241, 220, 226, 0.3);
  --clay-shadow-blue: 0px 5px 12px 0px rgba(220, 234, 241, 0.3);
  --clay-shadow-beige: 0px 5px 12px 0px rgba(244, 230, 214, 0.3);
  --clay-shadow-mint: 0px 5px 12px 0px rgba(226, 241, 230, 0.3);
  --clay-shadow-lavender: 0px 4px 10px 0px rgba(221, 214, 234, 0.35);
  --clay-shadow-beige-heavy: 0px 4px 8px 0px rgba(244, 230, 214, 0.35);
  --clay-shadow-upload-icon: 0px 6px 14px 0px rgba(241, 220, 226, 0.4);
  --clay-shadow-avatar: 0px 8px 20px 0px rgba(241, 220, 226, 0.4);
  --clay-shadow-save: 0px 3px 6px 0px rgba(255, 168, 122, 0.3);

  /* 阴影 - 3D 页面 */
  --clay-shadow-3d-viewer: 0px 8px 24px 0px rgba(221, 214, 234, 0.35);
  --clay-shadow-3d-control: 0px 3px 6px 0px rgba(230, 198, 179, 0.2);
  --clay-shadow-3d-info: 0px 4px 10px 0px rgba(230, 198, 179, 0.2);

  /* 圆角 */
  --clay-radius-sm: 12rpx;
  --clay-radius-md: 16rpx;
  --clay-radius-lg: 18rpx;
  --clay-radius-xl: 20rpx;
  --clay-radius-xxl: 24rpx;
  --clay-radius-round: 9999rpx;

  /* 字体大小 (rpx, 设计稿375px = 750rpx) */
  --clay-font-xs: 20rpx;
  --clay-font-sm: 24rpx;
  --clay-font-md: 26rpx;
  --clay-font-body: 28rpx;
  --clay-font-lg: 30rpx;
  --clay-font-xl: 34rpx;
  --clay-font-xxl: 36rpx;
  --clay-font-title: 40rpx;

  /* 间距 */
  --clay-spacing-xs: 8rpx;
  --clay-spacing-sm: 16rpx;
  --clay-spacing-md: 20rpx;
  --clay-spacing-lg: 28rpx;
  --clay-spacing-xl: 32rpx;
  --clay-spacing-xxl: 40rpx;
}