/* media_card.wxss - 媒体卡片组件样式 */

.media-card {
  border-radius: 8px;
  overflow: hidden;
  background-color: #ffffff;
}

.media-info {
  padding: 8px;
}

.media-title {
  display: block;
  font-size: 14px;
  color: #323233;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.media-age {
  display: block;
  font-size: 12px;
  color: #969799;
}