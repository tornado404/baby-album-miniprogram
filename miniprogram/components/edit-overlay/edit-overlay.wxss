.overlay-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 500;
}
.overlay-sheet {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fffbf8; border-radius: 36rpx 36rpx 0 0;
  z-index: 501; max-height: 80vh; overflow-y: auto;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
}
.sheet-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.sheet-title { font-size: 34rpx; font-weight: 700; color: #4a4a4a; }
.sheet-count { font-size: 26rpx; color: #999; }
.sheet-thumb-wrap { width: 160rpx; height: 160rpx; border-radius: 24rpx; overflow: hidden; margin: 0 auto 24rpx; background: #f1dce2; display: flex; align-items: center; justify-content: center; }
.sheet-thumb { width: 100%; height: 100%; }
.sheet-thumb-placeholder { font-size: 64rpx; color: #998080; }
.sheet-section { margin-bottom: 24rpx; }
.section-label { font-size: 26rpx; font-weight: 600; color: #4a4a4a; margin-bottom: 12rpx; display: block; }
.section-row { display: flex; gap: 16rpx; }
.section-input { width: 100%; height: 72rpx; background: #ffffff; border-radius: 18rpx; padding: 0 24rpx; font-size: 26rpx; color: #4a4a4a; box-shadow: 0px 2px 6px rgba(230,198,179,0.15); }
.tags-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag-chip { padding: 12rpx 24rpx; border-radius: 24rpx; font-size: 24rpx; color: #666; background: #ffffff; border: 2rpx solid #e6e6e6; }
.tag-chip.active { color: #ffffff; border-color: transparent; }
.custom-tag-row { display: flex; gap: 16rpx; margin-top: 16rpx; }
.custom-tag-input { flex: 1; height: 64rpx; background: #ffffff; border-radius: 18rpx; padding: 0 20rpx; font-size: 24rpx; box-shadow: 0px 2px 6px rgba(230,198,179,0.15); }
.custom-tag-btn { height: 64rpx; padding: 0 24rpx; background: #ffa87a; border-radius: 18rpx; display: flex; align-items: center; font-size: 26rpx; color: #fff; font-weight: 600; }
.milestone-scroll { display: flex; white-space: nowrap; padding: 8rpx 0; }
.milestone-item { display: inline-flex; flex-direction: column; align-items: center; padding: 16rpx 20rpx; margin-right: 16rpx; border-radius: 20rpx; background: #ffffff; box-shadow: 0px 2px 6px rgba(230,198,179,0.15); }
.milestone-item.active { border: 3rpx solid #ffa87a; transform: scale(1.05); }
.milestone-icon { font-size: 40rpx; }
.milestone-label { font-size: 20rpx; color: #666; margin-top: 4rpx; }
.sheet-nav { display: flex; gap: 20rpx; margin: 24rpx 0; }
.nav-btn { flex: 1; height: 80rpx; border-radius: 40rpx; background: #ffffff; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #4a4a4a; font-weight: 500; box-shadow: 0px 2px 6px rgba(230,198,179,0.2); }
.nav-btn.disabled { opacity: 0.4; }
.save-all-btn { width: 100%; height: 96rpx; border-radius: 48rpx; background: #ffa87a; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #fff; font-weight: 600; box-shadow: 0px 4px 12px rgba(255,168,122,0.3); }