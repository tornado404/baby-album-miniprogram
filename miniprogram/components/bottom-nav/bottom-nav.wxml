<view class="bottom-nav">
  <view
    wx:for="{{tabs}}"
    wx:key="key"
    class="bottom-nav-item {{item.key === current ? 'active' : ''}}"
    data-key="{{item.key}}"
    bindtap="onTabTap"
  >
    <text class="nav-icon">{{item.icon}}</text>
    <text class="nav-label">{{item.label}}</text>
  </view>
</view>