/* bottom-nav.wxss - Claymorphism 底部导航样式 */

.bottom-nav {
  display: flex;
  align-items: center;
  height: 128rpx;
  padding: 12rpx 0;
  background: var(--clay-card-white);
  box-shadow: var(--clay-shadow-nav);
  box-sizing: border-box;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.bottom-nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  min-width: 0;
  color: var(--clay-text-secondary);
}

.bottom-nav-item.active {
  color: var(--clay-primary);
}

.nav-icon {
  font-size: 40rpx;
  line-height: 1;
}

.nav-label {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 500;
}

.bottom-nav-item.active .nav-label {
  font-weight: 600;
}

/* 安全区域适配 */
.bottom-nav {
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
}