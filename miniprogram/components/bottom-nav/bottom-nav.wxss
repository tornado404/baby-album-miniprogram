/* bottom-nav.wxss - v2 3 Tab (成长/记录/我的) */

.bottom-nav {
  display: flex;
  align-items: center;
  height: 100rpx;
  background: #ffffff;
  box-shadow: 0px -2px 8px 0px rgba(230, 198, 179, 0.2);
  box-sizing: border-box;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

.bottom-nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #999;
}

.bottom-nav-item.active {
  color: #ffa87a;
}

.nav-icon {
  font-size: 48rpx;
  line-height: 1;
}

.nav-label {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 400;
}

.bottom-nav-item.active .nav-label {
  font-weight: 600;
}