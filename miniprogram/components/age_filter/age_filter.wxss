/* age_filter.wxss - 月龄筛选组件样式 */

.age-filter-container {
  background-color: #ffffff;
  padding: 12px 0;
}

.quick-filter {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 0 12px;
}

.filter-tag {
  display: inline-block;
  padding: 8px 16px;
  margin-right: 8px;
  border-radius: 16px;
  background-color: #f7f8fa;
  font-size: 14px;
  color: #646566;
}

.filter-tag.active {
  background-color: #1989fa;
  color: #ffffff;
}

.custom-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

/* 自定义筛选弹窗样式 */
.custom-picker {
  padding: 16px;
}

.picker-header {
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 16px;
}

.picker-content {
  margin-bottom: 16px;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f7f8fa;
}

.picker-row:last-child {
  border-bottom: none;
}

.picker-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
}