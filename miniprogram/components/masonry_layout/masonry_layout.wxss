/* masonry_layout.wxss - 瀑布流布局组件样式
 * 使用 CSS columns 实现瀑布流布局
 */

.masonry-container {
  width: 100%;
}

.masonry-row {
  width: 100%;
  /* 使用 CSS columns 实现瀑布流，列数由 JS 动态设置 */
  column-count: var(--column-count, 2);
  column-gap: var(--column-gap, 8px);
}

.masonry-column {
  /* column 内不需要额外样式 */
}

.masonry-item {
  /* 防止跨列断裂 */
  break-inside: avoid;
  margin-bottom: var(--item-gap, 8px);
}

.load-more-trigger {
  height: 20px;
}