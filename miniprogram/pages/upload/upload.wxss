/* upload.wxss - 上传页面 Claymorphism 样式 */

.page-upload {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Status Bar */
.status-bar {
  flex-shrink: 0;
}

/* Navigation Bar */
.upload-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
  padding: 0 40rpx;
  flex-shrink: 0;
}

.upload-nav .nav-btn-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: var(--clay-icon-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.upload-nav .nav-btn-circle text {
  font-size: 40rpx;
  color: var(--clay-text-primary);
  font-weight: 600;
}

.upload-nav .nav-title {
  font-size: var(--clay-font-xxl);
  font-weight: 700;
  color: var(--clay-text-primary);
}

.upload-nav .nav-spacer {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

/* Content Area */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 0;
  width: 750rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

/* Upload Card */
.upload-card {
  width: 670rpx;
  background: var(--clay-card-white);
  border-radius: var(--clay-radius-xxl);
  box-shadow: var(--clay-shadow-card-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 48rpx 40rpx;
  flex-shrink: 0;
}

.upload-icon-circle {
  width: 216rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: var(--clay-card-pink);
  box-shadow: var(--clay-shadow-upload-icon);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-icon-circle text {
  font-size: 64rpx;
}

.upload-hint {
  font-size: var(--clay-font-lg);
  color: var(--clay-text-pink);
  font-weight: 500;
}

.upload-subhint {
  font-size: var(--clay-font-md);
  color: var(--clay-text-muted);
}

/* Section Title */
.section-title {
  font-size: var(--clay-font-lg);
  color: var(--clay-text-primary);
  font-weight: 600;
  padding: 16rpx 0 0;
  text-align: center;
}

/* Upload Options */
.upload-option {
  width: 642rpx;
  height: 144rpx;
  background: var(--clay-card-white);
  border-radius: var(--clay-radius-xxl);
  box-shadow: var(--clay-shadow-card-light);
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 0 32rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  margin: 0 auto;
}

.option-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-icon text {
  font-size: 44rpx;
}

.option-icon-pink {
  background: var(--clay-card-pink);
}

.option-icon-blue {
  background: var(--clay-card-blue);
}

.option-icon-beige {
  background: var(--clay-card-beige);
}

.option-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.option-title {
  font-size: var(--clay-font-body);
  color: var(--clay-text-primary);
  font-weight: 600;
}

.option-desc {
  font-size: var(--clay-font-sm);
  color: var(--clay-text-secondary);
}

.option-arrow {
  font-size: 44rpx;
  color: var(--clay-text-muted);
  font-weight: 500;
  flex-shrink: 0;
}