/* upload.wxss - 记录页 v2 (4步渐进流程) */

.page-upload {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fffbf8;
}

/* ---- Status Bar ---- */
.status-bar {
  flex-shrink: 0;
}

/* ---- Navigation Bar ---- */
.upload-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
  padding: 0 40rpx;
  flex-shrink: 0;
}

.upload-nav .nav-btn-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #f9f0e9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.upload-nav .nav-btn-circle text {
  font-size: 40rpx;
  color: #4a4a4a;
  font-weight: 600;
}

.upload-nav .nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
  flex: 1;
  text-align: center;
}

/* Step Badge */
.step-badge {
  background: #ffa87a;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  flex-shrink: 0;
}

.step-badge text {
  font-size: 22rpx;
  font-weight: 500;
  color: #ffffff;
}

/* ---- Content Area ---- */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 20rpx 160rpx;
  width: 750rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

/* ========== Step 1: 选择来源 ========== */
.step1-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
  width: 100%;
}

.step1-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a4a4a;
  margin-bottom: 40rpx;
  align-self: flex-start;
  padding-left: 8rpx;
}

.upload-option {
  width: 670rpx;
  height: 200rpx;
  background: #ffffff;
  border-radius: 48rpx;
  box-shadow: 0px 4px 10px 0px rgba(230, 198, 179, 0.25);
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 0 32rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.option-big-icon {
  font-size: 72rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.option-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #4a4a4a;
}

.option-desc {
  font-size: 26rpx;
  font-weight: 400;
  color: #999;
}

.option-arrow {
  font-size: 52rpx;
  color: #ccc;
  font-weight: 500;
  flex-shrink: 0;
  line-height: 1;
}

/* ========== Step 2: 确认信息 ========== */
.step2-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 16rpx;
  width: 100%;
}

/* File Count Badge */
.file-count-badge {
  background: #f9f0e9;
  height: 36px;  /* Figma: 36px */
  border-radius: 18px;  /* Figma: 18px */
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 16px;  /* Figma: left 16px */
  width: 335px;  /* Figma: 335px */
  flex-shrink: 0;
  margin-bottom: 12px;  /* spacing to thumbs */
}

.file-count-badge text {
  font-size: 26rpx;  /* Figma: 13px font, ~26rpx */
  font-weight: 500;
  color: #4a4a4a;
}

/* Thumbnail Grid (4 in a row) */
.thumb-grid {
  display: flex;
  gap: 7px;  /* 83-76=7px gap in Figma */
  width: 335px;  /* match badge width */
  margin-bottom: 16px;  /* spacing to form */
}

.thumb-item {
  width: 76px;  /* Figma: 76px */
  height: 76px;  /* Figma: 76px */
  border-radius: 24rpx;  /* Figma: 12px ≈ 24rpx */
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.thumb-item text {
  font-size: 48rpx;
  line-height: 1;
}

.thumb-empty {
  background: #f1dce2;
  opacity: 0.5;
}

/* Form Fields */
.form-fields {
  width: 335px;  /* 335px */
  display: flex;
  flex-direction: column;
  gap: 8px;  /* 252+8-160=... */
}

.form-field {
  background: #ffffff;
  height: 80px;  /* Figma: 80px */
  border-radius: 32rpx;  /* Figma: 16px ≈ 32rpx */
  box-shadow: 0px 2px 6px 0px rgba(230, 198, 179, 0.15);  /* Figma: 0px 2px 6px */
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 16px;  /* Figma: left 16px */
  box-sizing: border-box;
}

.field-label {
  font-size: 26rpx;  /* Figma: 13px */
  font-weight: 500;
  color: #4a4a4a;
  display: block;
  margin-bottom: 4px;
}

.field-value {
  font-size: 28rpx;
  font-weight: 400;
  color: #333;
  display: block;
}

.field-placeholder {
  color: #999;
}

.form-field-desc {
  height: 100px;  /* Figma: 100px */
}

/* Milestone Dropdown */
.field-with-dropdown {
  position: relative;
}

.dropdown-arrow {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #999;
}

.milestone-dropdown {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0px 8rpx 32rpx 0px rgba(230, 198, 179, 0.35);
  margin-top: 4px;
  overflow: hidden;
}

.milestone-list {
  max-height: 320rpx;
  overflow-y: auto;
}

.milestone-item {
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f5f0ec;
}

.milestone-item:last-child {
  border-bottom: none;
}

.milestone-item text {
  font-size: 28rpx;
  color: #4a4a4a;
}

.milestone-item-active {
  background: #fff5f0;
}

.milestone-item-active text {
  color: #ffa87a;
  font-weight: 600;
}

.milestone-custom {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 2rpx solid #ffa87a;
  gap: 16rpx;
}

.milestone-input {
  flex: 1;
  height: 64rpx;
  background: #f9f0e9;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #4a4a4a;
}

.milestone-confirm-btn {
  background: #ffa87a;
  border-radius: 16rpx;
  height: 64rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.milestone-confirm-btn text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

/* Confirm Button */
.confirm-btn {
  width: 335px;
  height: 50px;  /* Figma: 50px */
  background: #ffa87a;
  border-radius: 25px;  /* Figma: 25px */
  box-shadow: 0px 4px 8px 0px rgba(230, 198, 179, 0.3);  /* Figma: 0px 4px 8px */
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12px;
}

.confirm-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ========== Step 3: 上传中 ========== */
.step3-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60px;  /* Figma: top 100px - offset */
  width: 100%;
}

/* Upload Card */
.upload-card {
  width: 295px;  /* Figma: 295px */
  background: #ffffff;
  border-radius: 48rpx;  /* Figma: 24px */
  box-shadow: 0px 12rpx 32rpx 0px rgba(230, 198, 179, 0.3);
  padding: 20px 24px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-card-icon {
  font-size: 96rpx;
  color: #4a4a4a;
  display: block;
  margin-bottom: 12px;
}

.progress-bar {
  width: 247px;  /* Figma: 247px */
  height: 12px;  /* Figma: 12px */
  background: #f9f0e9;  /* Figma: #f9f0e9 */
  border-radius: 6px;  /* Figma: 6px */
  margin-bottom: 8px;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: #ffa87a;  /* Figma: #ffa87a */
  border-radius: 6px;
  transition: width 0.3s;
}

.upload-card-pct {
  font-size: 28rpx;  /* Figma: 14px */
  font-weight: 600;
  color: #4a4a4a;
  display: block;
  align-self: flex-start;
  margin-bottom: 4px;
}

.upload-card-info {
  font-size: 26rpx;  /* Figma: 13px */
  font-weight: 400;
  color: #999;
  display: block;
  align-self: flex-start;
}

/* Step 3 Action Buttons */
.step3-actions {
  display: flex;
  gap: 12px;
  margin-top: 40px;  /* Figma: top 320px - offset */
}

.step3-btn {
  width: 130px;  /* Figma: 130px */
  height: 42px;  /* Figma: 42px */
  border-radius: 21px;  /* Figma: 21px */
  display: flex;
  align-items: center;
  justify-content: center;
}

.step3-btn text {
  font-size: 30rpx;  /* Figma: 15px */
  font-weight: 500;
}

.step3-btn-cancel {
  background: #ffffff;
  border: 1.5px solid #e0e0e0;  /* Figma: border #e0e0e0 */
}

.step3-btn-cancel text {
  color: #999;  /* Figma: #999 */
}

.step3-btn-retry {
  background: #ffa87a;
}

.step3-btn-retry text {
  color: #ffffff;
}

/* Current File Preview */
.step3-preview {
  width: 120px;  /* Figma: 120px */
  height: 120px;  /* Figma: 120px */
  border-radius: 32rpx;  /* Figma: 16px */
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40px;  /* Figma: top 400px */
}

.step3-preview text {
  font-size: 64rpx;
}

/* ========== Step 4: 完成反馈 ========== */
.step4-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60px;  /* Figma: top offset */
  width: 100%;
}

.step4-checkmark {
  font-size: 128rpx;  /* Figma: 64px */
  color: #4a4a4a;
  display: block;
  margin-bottom: 16px;
}

.step4-title {
  font-size: 40rpx;  /* Figma: 20px */
  font-weight: 600;
  color: #4a4a4a;
  display: block;
  margin-bottom: 24px;
}

/* Thumbnails Row (5) */
.step4-thumbs {
  display: flex;
  gap: 12px;  /* 64-52=12px */
  margin-bottom: 40px;
  justify-content: center;
  width: 300px;  /* Figma: 300px */
}

.step4-thumb {
  width: 52px;  /* Figma: 52px */
  height: 52px;  /* Figma: 52px */
  border-radius: 24rpx;  /* Figma: 12px */
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step4-thumb text {
  font-size: 40rpx;
  line-height: 1;
}

/* Step 4 Action Buttons */
.step4-actions {
  display: flex;
  gap: 10px;  /* 28px gap + button widths */
  justify-content: center;
  width: 100%;
  padding: 0 28px;
  box-sizing: border-box;
}

.step4-btn {
  height: 50px;  /* Figma: 50px */
  border-radius: 25px;  /* Figma: 25px */
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  max-width: 160px;  /* Figma: 160px */
}

.step4-btn text {
  font-size: 30rpx;  /* Figma: 15px */
  font-weight: 600;
}

.step4-btn-primary {
  background: #ffa87a;
  box-shadow: 0px 8rpx 16rpx 0px rgba(230, 198, 179, 0.3);  /* Figma shadow */
}

.step4-btn-primary text {
  color: #ffffff;
}

.step4-btn-outline {
  background: #ffffff;
  border: 1.5px solid #ffa87a;
}

.step4-btn-outline text {
  color: #ffa87a;
}