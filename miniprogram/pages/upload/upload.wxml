<view class="page page-upload">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="upload-nav">
    <view class="nav-btn-circle" bindtap="onBack">
      <text>←</text>
    </view>
    <text class="nav-title">上传记录</text>
    <view class="nav-spacer"></view>
  </view>

  <!-- Content Area -->
  <scroll-view class="content-area" scroll-y enable-flex>
    <!-- Upload Card -->
    <view class="upload-card">
      <view class="upload-icon-circle">
        <text>📷</text>
      </view>
      <text class="upload-hint">点击上传照片或视频</text>
      <text class="upload-subhint">支持 JPG / PNG / MP4</text>
    </view>

    <!-- Upload Method Title -->
    <text class="section-title">选择上传方式</text>

    <!-- Option: 拍照上传 -->
    <view class="upload-option" bindtap="onTakePhoto">
      <view class="option-icon option-icon-pink">
        <text>📸</text>
      </view>
      <view class="option-text">
        <text class="option-title">拍照上传</text>
        <text class="option-desc">用相机拍摄宝宝精彩瞬间</text>
      </view>
      <text class="option-arrow">›</text>
    </view>

    <!-- Option: 相册选择 -->
    <view class="upload-option" bindtap="onChooseFromAlbum">
      <view class="option-icon option-icon-blue">
        <text>🖼️</text>
      </view>
      <view class="option-text">
        <text class="option-title">相册选择</text>
        <text class="option-desc">从手机相册中挑选</text>
      </view>
      <text class="option-arrow">›</text>
    </view>

    <!-- Option: 3D模型 -->
    <view class="upload-option" bindtap="onUpload3D">
      <view class="option-icon option-icon-beige">
        <text>🧸</text>
      </view>
      <view class="option-text">
        <text class="option-title">3D模型</text>
        <text class="option-desc">上传宝宝3D立体模型</text>
      </view>
      <text class="option-arrow">›</text>
    </view>
  </scroll-view>

  <!-- Bottom Navigation -->
  <bottom-nav current="upload"></bottom-nav>
</view>