<view class="page page-upload">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="upload-nav">
    <view class="nav-btn-circle" bindtap="onBack">
      <text>←</text>
    </view>
    <text class="nav-title">记录成长</text>
    <view class="nav-spacer"></view>
  </view>

  <!-- Content Area -->
  <scroll-view class="content-area" scroll-y enable-flex>

    <!-- Step Badge -->
    <view class="step-badge">
      <text>步骤 1/4</text>
    </view>

    <!-- Option: 拍照 -->
    <view class="upload-option" bindtap="onTakePhoto">
      <text class="option-big-icon">📷</text>
      <view class="option-text">
        <text class="option-title">拍照</text>
        <text class="option-desc">用相机拍摄宝宝精彩瞬间</text>
      </view>
      <text class="option-arrow">›</text>
    </view>

    <!-- Option: 相册 -->
    <view class="upload-option" bindtap="onChooseFromAlbum">
      <text class="option-big-icon">🖼️</text>
      <view class="option-text">
        <text class="option-title">相册</text>
        <text class="option-desc">从手机相册中挑选照片和视频</text>
      </view>
      <text class="option-arrow">›</text>
    </view>

    <!-- Step 2 Preview (step preview, dimmed) -->
    <view class="step-preview">
      <text class="step-preview-title">步骤 2/4: 确认信息</text>
      <view class="step-preview-thumbs">
        <text class="thumb-icon">📷</text>
        <text class="thumb-icon">📷</text>
        <text class="thumb-icon">🎬</text>
      </view>
      <text class="step-preview-hint">已选择 3 个文件 · 填写描述和里程碑</text>
    </view>

    <!-- Step 3 Preview -->
    <view class="step-preview">
      <text class="step-preview-title">步骤 3/4: 上传中</text>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: 50%;"></view>
      </view>
      <text class="step-preview-hint">第 3 张 / 共 6 张 · 50%</text>
    </view>

    <!-- Step 4 Preview -->
    <view class="step-preview">
      <text class="step-preview-title">步骤 4/4: ✅ 已加入成长相册</text>
      <view class="step-preview-thumbs">
        <text class="thumb-icon-sm">📷</text>
        <text class="thumb-icon-sm">📷</text>
        <text class="thumb-icon-sm">📷</text>
        <text class="thumb-icon-sm">📷</text>
      </view>
    </view>

  </scroll-view>

  <!-- Upload Progress Overlay -->
  <view wx:if="{{isUploading}}" class="upload-progress-overlay">
    <view class="upload-progress-card">
      <text class="progress-emoji">📤</text>
      <view class="progress-bar-bg big">
        <view class="progress-bar-fill" style="width: {{uploadProgress}}%;"></view>
      </view>
      <text class="progress-pct">{{uploadProgress}}%</text>
      <text class="progress-status">{{uploadStatus}}</text>
      <view class="progress-actions">
        <view class="progress-btn progress-btn-cancel" bindtap="onCancelUpload">
          <text>取消</text>
        </view>
        <view class="progress-btn progress-btn-retry" bindtap="onRetryUpload">
          <text>重试</text>
        </view>
      </view>
      <view class="current-file-preview">
        <text>📷</text>
      </view>
    </view>
  </view>

  <!-- Bottom Navigation -->
  <bottom-nav current="record"></bottom-nav>
</view>