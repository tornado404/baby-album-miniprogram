<view class="page page-upload">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="upload-nav">
    <view class="nav-btn-circle" bindtap="onBack">
      <text>←</text>
    </view>
    <text class="nav-title">{{navTitle}}</text>
    <view class="step-badge">
      <text>步骤 {{currentStep}}/4</text>
    </view>
  </view>

  <!-- Content Area -->
  <scroll-view class="content-area" scroll-y>

    <!-- ===== Step 1: 选择来源 ===== -->
    <block wx:if="{{currentStep === 1}}">
      <view class="step1-section">
        <text class="step1-title">今天记录宝宝的一个瞬间</text>

        <view class="upload-option" bindtap="onTakePhoto">
          <text class="option-big-icon">📷</text>
          <view class="option-text">
            <text class="option-title">拍照</text>
            <text class="option-desc">用相机拍摄宝宝精彩瞬间</text>
          </view>
          <text class="option-arrow">›</text>
        </view>

        <view class="upload-option" bindtap="onChooseFromAlbum">
          <text class="option-big-icon">🖼️</text>
          <view class="option-text">
            <text class="option-title">相册</text>
            <text class="option-desc">从手机相册中挑选照片和视频</text>
          </view>
          <text class="option-arrow">›</text>
        </view>
      </view>
    </block>

    <!-- ===== Step 2: 确认信息 ===== -->
    <block wx:elif="{{currentStep === 2}}">
      <view class="step2-section">

        <!-- File Count Badge -->
        <view class="file-count-badge">
          <text>已选择 {{selectedFiles.length}} 个文件</text>
        </view>

        <!-- Thumbnail Grid -->
        <view class="thumb-grid">
          <view
            wx:for="{{selectedFiles}}"
            wx:key="index"
            class="thumb-item"
            style="background-color: {{thumbColors[index % 4]}};"
          >
            <text>{{item.mediaType === 'video' ? '🎬' : '📷'}}</text>
          </view>
          <view wx:if="{{selectedFiles.length === 0}}" class="thumb-item thumb-empty">
            <text>?</text>
          </view>
        </view>

        <!-- Form Fields -->
        <view class="form-fields">

          <!-- 宝宝 -->
          <view class="form-field">
            <text class="field-label">宝宝</text>
            <text class="field-value">{{babyName || '选择宝宝'}}</text>
          </view>

          <!-- 日期 -->
          <view class="form-field" bindtap="onPickDate">
            <text class="field-label">日期</text>
            <text class="field-value">{{captureDate || todayDate}}</text>
          </view>

          <!-- 里程碑 -->
          <view class="form-field" bindtap="onPickMilestone">
            <text class="field-label">里程碑</text>
            <text class="field-value field-placeholder">{{milestone || '选择里程碑（选填）'}}</text>
          </view>

          <!-- 描述 -->
          <view class="form-field form-field-desc" bindtap="onInputDescription">
            <text class="field-label">描述</text>
            <text class="field-value field-placeholder">{{description || '这一天的故事...（选填）'}}</text>
          </view>

        </view>

        <!-- Confirm Button -->
        <view class="confirm-btn" bindtap="onConfirmUpload">
          <text>确认记录</text>
        </view>

      </view>
    </block>

    <!-- ===== Step 3: 上传中 ===== -->
    <block wx:elif="{{currentStep === 3}}">
      <view class="step3-section">

        <!-- Upload Card -->
        <view class="upload-card">
          <text class="upload-card-icon">📤</text>
          <view class="progress-bar">
            <view class="progress-bar-fill" style="width: {{uploadProgress}}%;"></view>
          </view>
          <text class="upload-card-pct">{{uploadProgress}}%</text>
          <text class="upload-card-info">第 {{uploadCurrentFile}} 张 · 共 {{selectedFiles.length}} 张</text>
        </view>

        <!-- Action Buttons -->
        <view class="step3-actions">
          <view class="step3-btn step3-btn-cancel" bindtap="onCancelUpload">
            <text>取消</text>
          </view>
          <view class="step3-btn step3-btn-retry" bindtap="onRetryUpload">
            <text>重试</text>
          </view>
        </view>

        <!-- Current File Preview -->
        <view class="step3-preview" style="background-color: {{thumbColors[uploadCurrentFile % 4]}};">
          <text>📷</text>
        </view>

      </view>
    </block>

    <!-- ===== Step 4: 完成反馈 ===== -->
    <block wx:elif="{{currentStep === 4}}">
      <view class="step4-section">

        <text class="step4-checkmark">✅</text>
        <text class="step4-title">已加入成长相册</text>

        <!-- Thumbnails Row -->
        <view class="step4-thumbs">
          <view
            wx:for="{{selectedFiles}}"
            wx:key="index"
            class="step4-thumb"
            style="background-color: {{thumbColors[index % 4]}};"
          >
            <text>{{item.mediaType === 'video' ? '🎬' : '📷'}}</text>
          </view>
        </view>

        <!-- Action Buttons -->
        <view class="step4-actions">
          <view class="step4-btn step4-btn-primary" bindtap="onViewRecord">
            <text>查看记录</text>
          </view>
          <view class="step4-btn step4-btn-outline" bindtap="onContinueUpload">
            <text>继续上传</text>
          </view>
        </view>

      </view>
    </block>

  </scroll-view>

  <!-- Bottom Navigation -->
  <bottom-nav current="record"></bottom-nav>
</view>