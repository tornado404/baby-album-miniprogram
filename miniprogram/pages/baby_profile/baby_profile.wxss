/* baby_profile.wxss - 宝宝档案页面 Claymorphism 样式 */

.page-profile {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.status-bar {
  flex-shrink: 0;
}

/* Navigation Bar */
.profile-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
  padding: 0 40rpx 0 24rpx;
  flex-shrink: 0;
}

.profile-nav .nav-btn-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: var(--clay-icon-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-nav .nav-btn-circle text {
  font-size: 40rpx;
  color: var(--clay-text-primary);
  font-weight: 600;
}

.profile-nav .nav-title {
  font-size: var(--clay-font-xxl);
  font-weight: 700;
  color: var(--clay-text-primary);
}

.nav-save-btn {
  height: 64rpx;
  background: var(--clay-primary);
  border-radius: 32rpx;
  box-shadow: var(--clay-shadow-save);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
}

.nav-save-btn text {
  font-size: var(--clay-font-md);
  font-weight: 600;
  color: #fff;
}

/* Content Area */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
  padding: 40rpx 0;
  box-sizing: border-box;
  overflow-y: auto;
}

/* Avatar */
.avatar-card {
  display: flex;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
  background: var(--clay-card-pink);
  box-shadow: var(--clay-shadow-avatar);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-circle text {
  font-size: 108rpx;
}

/* Fields */
.fields-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
  width: 670rpx;
  flex-shrink: 0;
}

.field-item {
  width: 100%;
  height: 128rpx;
  background: var(--clay-card-white);
  border-radius: var(--clay-radius-xxl);
  box-shadow: var(--clay-shadow-card-light);
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 24rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.field-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: var(--clay-icon-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.field-icon text {
  font-size: 36rpx;
}

.field-label {
  font-size: var(--clay-font-body);
  color: var(--clay-text-light);
  flex-shrink: 0;
}

.field-spacer {
  flex: 1;
  min-width: 16rpx;
}

/* Text Input */
.field-input {
  height: 72rpx;
  background: #faf9f8;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.field-text-input {
  font-size: var(--clay-font-body);
  font-weight: 500;
  color: var(--clay-text-primary);
  text-align: right;
  min-width: 160rpx;
}

.field-cursor {
  width: 3rpx;
  height: 32rpx;
  background: var(--clay-primary);
  border-radius: 2rpx;
  margin-left: 4rpx;
  animation: blink 1s step-end infinite;
}

@keyframes blink {
  50% { opacity: 0; }
}

/* Gender Picker */
.gender-picker {
  height: 72rpx;
  background: #faf9f8;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 8rpx;
  flex-shrink: 0;
}

.gender-option {
  height: 56rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
}

.gender-option.active {
  background: var(--clay-primary);
}

.gender-option text {
  font-size: var(--clay-font-md);
  font-weight: 500;
  color: var(--clay-text-light);
}

.gender-option.active text {
  font-weight: 600;
  color: #fff;
}

/* Date Input */
.field-date-input {
  height: 72rpx;
  background: #faf9f8;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.date-text {
  font-size: var(--clay-font-body);
  font-weight: 500;
  color: var(--clay-text-primary);
}

.date-icon {
  font-size: 28rpx;
}

/* Number Input */
.field-number-input {
  height: 72rpx;
  background: #faf9f8;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.num-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.num-minus {
  background: var(--clay-icon-bg);
}

.num-plus {
  background: var(--clay-primary);
}

.num-btn text {
  font-size: 32rpx;
  font-weight: 600;
}

.num-minus text {
  color: var(--clay-text-pink);
}

.num-plus text {
  color: #fff;
}

.num-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--clay-text-primary);
  min-width: 40rpx;
  text-align: center;
}

.num-unit {
  font-size: var(--clay-font-md);
  color: var(--clay-text-secondary);
}