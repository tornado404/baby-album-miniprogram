/* baby_profile.wxss - 宝宝档案页面 Claymorphism（精确 Figma 还原） */

.page-profile {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--clay-bg, #fffbf8);
}

.status-bar {
  flex-shrink: 0;
}

/* ---- Navigation Bar ---- */
.profile-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
  padding: 0 40rpx 0 24rpx;
  flex-shrink: 0;
}

.profile-nav .nav-btn-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #f9f0e9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.profile-nav .nav-btn-circle text {
  font-size: 40rpx;
  color: #4a4a4a;
  font-weight: 600;
}
.profile-nav .nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
}

/* Save button - orange pill with shadow */
.nav-save-btn {
  height: 64rpx;
  background: #ffa87a;
  border-radius: 32rpx;
  box-shadow: 0px 3px 6px 0px rgba(255, 168, 122, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
}
.nav-save-btn text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

/* Spacer to balance nav bar (replaces removed save button) */
.nav-spacer-right {
  width: 28px;
  height: 36px;
  flex-shrink: 0;
}

/* ---- Content Area ---- */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
  padding: 40rpx 0 160rpx;
  width: 750rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

/* Avatar Card - pink circle with shadow */
.avatar-card {
  display: flex;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
  background: #f1dce2;
  box-shadow: 0px 8px 20px 0px rgba(241, 220, 226, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-circle text {
  font-size: 108rpx;
  color: #806680;
}

.profile-avatar-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
}

/* ---- Fields Wrapper ---- */
.fields-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx;
  width: 670rpx;
  flex-shrink: 0;
}

/* Field Item - white card with shadow */
.field-item {
  width: 100%;
  height: 128rpx;
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0px 3px 8px 0px rgba(230, 198, 179, 0.18);
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

/* Field Icon */
.field-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #f9f0e9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.field-icon text {
  font-size: 36rpx;
  color: #806666;
}

/* Field Label */
.field-label {
  font-size: 28rpx;
  color: #808080;
  flex-shrink: 0;
}

.field-spacer {
  flex: 1;
  min-width: 16rpx;
}

/* ---- Text Input ---- */
.field-input {
  height: 72rpx;
  background: #faf9f8;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  flex-shrink: 0;
}
.field-text-input {
  font-size: 28rpx;
  font-weight: 500;
  color: #4a4a4a;
  text-align: right;
  min-width: 160rpx;
}
.field-cursor {
  width: 3rpx;
  height: 32rpx;
  background: #ffa87a;
  border-radius: 2rpx;
  margin-left: 4rpx;
  animation: blink 1s step-end infinite;
}
@keyframes blink {
  50% { opacity: 0; }
}

/* ---- Gender Picker ---- */
.gender-picker {
  height: 72rpx;
  background: #faf9f8;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 8rpx;
  flex-shrink: 0;
}
.gender-option {
  height: 56rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
}
.gender-option.active {
  background: #ffa87a;
}
.gender-option text {
  font-size: 26rpx;
  font-weight: 500;
  color: #808080;
}
.gender-option.active text {
  font-weight: 600;
  color: #ffffff;
}

/* ---- Date Input ---- */
.field-date-input {
  height: 72rpx;
  background: #faf9f8;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 24rpx;
  flex-shrink: 0;
}
.date-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #4a4a4a;
}
.date-icon {
  font-size: 28rpx;
}

/* ---- Number Input ---- */
.field-number-input {
  height: 72rpx;
  background: #faf9f8;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 16rpx;
  flex-shrink: 0;
}
.num-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.num-minus {
  background: #f9f0e9;
}
.num-plus {
  background: #ffa87a;
}
.num-btn text {
  font-size: 32rpx;
  font-weight: 600;
}
.num-minus text {
  color: #806666;
}
.num-plus text {
  color: #ffffff;
}
.num-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a4a4a;
  min-width: 40rpx;
  text-align: center;
}
.num-unit {
  font-size: 26rpx;
  color: #999;
}

/* ---- Save Button (底部居中) ---- */
.save-btn-wrapper {
  display: flex;
  justify-content: center;
  width: 100%;
  padding: 16rpx 0 40rpx;
  flex-shrink: 0;
}

.save-btn {
  width: 400rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: #ffa87a;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0px 4px 12px 0px rgba(255, 168, 122, 0.3);
}

.save-btn-hover {
  opacity: 0.85;
  transform: scale(0.97);
}

.save-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}