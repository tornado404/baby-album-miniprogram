/* 3d_viewer.wxss - 3D模型查看页（精确 Figma 还原） */

.page-3d-viewer {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5edfa;
}

.status-bar {
  flex-shrink: 0;
}

/* ---- Navigation ---- */
.nav-3d {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.nav-circle-white {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0px 2px 4px 0px rgba(230, 198, 179, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-circle-white text {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
  line-height: 1;
}

.nav-3d .nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
}

/* ---- Content Area ---- */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  padding: 40rpx 0 64rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

/* ---- Viewer Container ---- */
.viewer-container {
  width: 670rpx;
  height: 760rpx;
  background: #ffffff;
  border-radius: 56rpx;
  box-shadow: 0px 8px 24px 0px rgba(221, 214, 234, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.viewer-bg {
  width: 560rpx;
  background: #faf5fc;
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 60rpx 0;
}

.model-emoji {
  font-size: 160rpx;
  color: #806680;
}

.model-preview-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #998c99;
}

/* ---- Controls Row ---- */
.controls-row {
  display: flex;
  gap: 24rpx;
  align-items: center;
  flex-shrink: 0;
}

.control-btn {
  width: 144rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0px 3px 6px 0px rgba(230, 198, 179, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  flex-shrink: 0;
}

.control-icon {
  font-size: 40rpx;
  color: #665973;
}

.control-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #808080;
}

/* ---- Model Info Card ---- */
.model-info-card {
  width: 670rpx;
  height: 160rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0px 4px 10px 0px rgba(230, 198, 179, 0.2);
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 0 40rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.model-info-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  background: #ddd6ea;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.model-info-icon text {
  font-size: 48rpx;
}

.model-info-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.model-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a4a4a;
}

.model-desc {
  font-size: 24rpx;
  color: #999;
}