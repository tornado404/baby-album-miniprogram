<!-- 3d_viewer.wxml - Claymorphism 3D模型查看页（精确 Figma 还原） -->
<view class="page-3d-viewer">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="nav-3d">
    <view class="nav-circle-white" bindtap="onBack">
      <text>←</text>
    </view>
    <text class="nav-title">3D 立体留念</text>
    <view class="nav-circle-white" bindtap="onShare">
      <text>📤</text>
    </view>
  </view>

  <!-- Content Area -->
  <view class="content-area">

    <!-- 3D Viewer Container -->
    <view class="viewer-container">
      <view class="viewer-bg">
        <text class="model-emoji">🧸</text>
        <text class="model-preview-label">3D 模型预览</text>
      </view>
    </view>

    <!-- Controls Row -->
    <view class="controls-row">
      <view class="control-btn">
        <text class="control-icon">🔄</text>
        <text class="control-label">旋转</text>
      </view>
      <view class="control-btn">
        <text class="control-icon">🔍</text>
        <text class="control-label">缩放</text>
      </view>
      <view class="control-btn">
        <text class="control-icon">📷</text>
        <text class="control-label">截图</text>
      </view>
      <view class="control-btn">
        <text class="control-icon">⛶</text>
        <text class="control-label">全屏</text>
      </view>
    </view>

    <!-- Model Info -->
    <view class="model-info-card">
      <view class="model-info-icon">
        <text>🎯</text>
      </view>
      <view class="model-info-text">
        <text class="model-title">满月3D纪念</text>
        <text class="model-desc">2026年1月1日 · 立体模型</text>
      </view>
    </view>
  </view>
</view>