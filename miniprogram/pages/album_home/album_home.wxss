.page-home {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fffbf8;
}
.status-bar {
  flex-shrink: 0;
}
.home-nav {
  display: flex;
  align-items: center;
  height: 104rpx;
  padding: 0 40rpx;
}
.home-nav-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a4a4a;
}
.clay-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}