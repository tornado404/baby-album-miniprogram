/* album_home.wxss - 成长 v2 (瀑布流 + 年龄段筛选 + 里程碑分组) */

.page-home {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fffbf8;
  overflow: hidden;
}

/* ---- Navigation Bar ---- */
.home-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
  padding: 0 40rpx;
  flex-shrink: 0;
}
.home-nav-left {
  flex: 1;
  min-width: 0;
}
.home-nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
}

/* ---- Baby Selector ---- */
.baby-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f9f0e9;
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
  max-width: 240rpx;
  flex-shrink: 0;
}
.baby-selector-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #4a4a4a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160rpx;
}
.baby-selector-arrow {
  font-size: 18rpx;
  color: #999;
}

/* ---- Baby Picker Overlay ---- */
.baby-picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.1);
}
.baby-picker-dropdown {
  position: absolute;
  top: 128rpx;
  right: 40rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0px 6px 24px 0px rgba(0, 0, 0, 0.12);
  min-width: 240rpx;
  overflow: hidden;
}
.baby-picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.baby-picker-item:last-child {
  border-bottom: none;
}
.baby-picker-item-active {
  background: #fff8f0;
}
.baby-picker-name {
  font-size: 26rpx;
  color: #4a4a4a;
}
.baby-picker-check {
  font-size: 24rpx;
  color: #ffa87a;
  margin-left: 16rpx;
}

/* ---- Content Area (Skyline scroll-view) ---- */
.clay-content {
  flex: 1;
  padding: 0 20rpx 160rpx;
  box-sizing: border-box;
  min-height: 0;
}

/* ---- Age Filter (v2 chip style) ---- */
.age-filter {
  display: flex;
  gap: 12rpx;
  align-items: center;
  padding: 20rpx 0 16rpx;
  width: 100%;
  flex-shrink: 0;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-chip {
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  flex-shrink: 0;
  background: #f9f0e9;
}
.filter-chip text {
  font-size: 24rpx;
  font-weight: 500;
  color: #4a4a4a;
}

.filter-chip.active {
  background: #ffa87a;
}
.filter-chip.active text {
  font-weight: 600;
  color: #ffffff;
}

/* ---- Loading / Empty ---- */
.load-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}
.load-state text,
.empty-state text {
  font-size: 28rpx;
  color: #999;
}
.empty-upload-btn {
  background: #ffa87a;
  border-radius: 32rpx;
  box-shadow: 0px 4px 8px 0px rgba(255, 168, 122, 0.4);
  padding: 16rpx 48rpx;
}
.empty-upload-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ---- Waterfall Sections ---- */
.waterfall-sections {
  width: 100%;
  flex-shrink: 0;
}

.milestone-section {
  margin-bottom: 8rpx;
}

/* ---- Milestone Header ---- */
.milestone-header {
  position: relative;
  padding: 20rpx 0 12rpx;
}
.milestone-icon {
  font-size: 32rpx;
  color: #ffa87a;
  position: absolute;
  left: 0;
  top: 20rpx;
  line-height: 1;
}
.milestone-info {
  margin-left: 48rpx;
}
.milestone-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a4a4a;
  display: block;
  line-height: 1.4;
}
.milestone-meta {
  font-size: 20rpx;
  font-weight: 400;
  color: #999;
  display: block;
  line-height: 1.4;
  margin-top: 4rpx;
}
.milestone-separator {
  height: 1px;
  background: #eee;
  margin-top: 8rpx;
  width: 100%;
}

/* ---- Waterfall Grid (2-column) ---- */
.waterfall-grid {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.waterfall-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ---- Media Card (v2 design) ---- */
.media-card {
  width: 100%;
  border-radius: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0px 3px 4px 0px rgba(230, 198, 179, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-thumb {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;  /* Figma: inner media 12px */
}

.media-type-icon {
  font-size: 44rpx;
  color: #999;
  z-index: 1;
  position: relative;
}

/* Date overlay (bottom-left) */
.media-date {
  position: absolute;
  bottom: 40rpx;  /* Figma: 20px from bottom */
  left: 16rpx;
  font-size: 20rpx;
  font-weight: 400;
  color: #ffffff;
  z-index: 2;
  text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.2);
}

/* Menu button (top-right, author only) */
.card-menu {
  position: absolute;
  top: 12rpx;
  right: 28rpx;  /* Figma: ~14px from right */
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.card-menu text {
  font-size: 32rpx;
  font-weight: 400;
  color: #ffffff;
  text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.2);
  line-height: 1;
}

/* Video duration badge */
.video-badge {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
  padding: 4rpx 10rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  z-index: 2;
}
.video-badge text {
  font-size: 20rpx;
  color: #ffffff;
  line-height: 1;
}