/* album_home.wxss - Claymorphism 首页（精确 Figma 还原） */

.page-home {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--clay-bg, #fffbf8);
}

/* ---- Navigation Bar ---- */
.home-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
  padding: 0 40rpx;
  align-items: center;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.home-nav-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a4a4a;
}

/* Right spacer to balance nav bar (replaces removed right buttons) */
.home-nav-spacer {
  width: 28px;
  height: 36px;
  flex-shrink: 0;
}

/* ---- Content Area ---- */
.clay-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx 160rpx;
  overflow-y: auto;
  height: 100%;
  box-sizing: border-box;
}

/* ===== Baby Header Container (展开/折叠双态) ===== */
.baby-header-container {
  width: 602rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0px 6px 16px 0px rgba(230, 198, 179, 0.35);
  flex-shrink: 0;
  overflow: hidden;
  transition: height 0.3s ease, padding 0.3s ease;
  position: relative;
}

.baby-header-container.expanded {
  height: 136rpx;
  padding: 0 32rpx;
  align-items: center;
}

.baby-header-container.collapsed {
  height: 90rpx;
  padding: 0 24rpx;
}

/* Expanded state */
.baby-header-expanded {
  display: flex;
  align-items: center;
  gap: 28rpx;
  width: 100%;
  height: 100%;
  transition: opacity 0.25s ease;
}

.baby-header-collapsed {
  display: flex;
  align-items: center;
  width: 100%;
  height: 100%;
  transition: opacity 0.25s ease;
}

.fade-out {
  opacity: 0;
  pointer-events: none;
}

/* Baby Info Header Card */
.baby-header-card {
  width: 602rpx;
  height: 136rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0px 6px 16px 0px rgba(230, 198, 179, 0.35);
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 0 32rpx;
  align-items: center;
  flex-shrink: 0;
}
.baby-header-avatar {
  width: 68rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #f1dce2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.baby-header-avatar text {
  font-size: 44rpx;
  color: #806680;
}

.header-avatar-image {
  width: 68rpx;
  height: 88rpx;
  border-radius: 44rpx;
}
.baby-header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.baby-header-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #4a4a4a;
}
.baby-header-age {
  font-size: 26rpx;
  font-weight: 500;
  color: #999;
}
.baby-header-setting {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #f9f0e9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.baby-header-setting text {
  font-size: 30rpx;
  color: #998066;
}

/* ===== Baby Strip (折叠态头像条) ===== */
.baby-strip-scroll {
  display: flex;
  flex-direction: row;
  width: 100%;
  height: 100%;
  overflow-x: auto;
  white-space: nowrap;
}

.baby-strip-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0 6rpx;
  height: 100%;
}

.strip-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.baby-strip-item.active .strip-avatar {
  box-shadow: 0 0 0 3rpx #ffa87a;
}

.strip-avatar text {
  font-size: 28rpx;
  color: #806680;
}

.strip-add-btn {
  padding-left: 10rpx;
}

.strip-add-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #ffa87a;
  box-shadow: 0px 3px 6px 0px rgba(255, 168, 122, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.strip-add-circle text {
  font-size: 36rpx;
  font-weight: 300;
  color: #ffffff;
  line-height: 1;
}

/* ---- Month Filter ---- */
.month-filter {
  display: flex;
  gap: 16rpx;
  align-items: center;
  padding: 20rpx 0;
  width: 670rpx;
  flex-shrink: 0;
  overflow-x: auto;
}
.filter-chip {
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  flex-shrink: 0;
}
.filter-chip text {
  font-size: 26rpx;
  font-weight: 500;
}
.filter-chip.active {
  background: #ffa87a;
  box-shadow: 0px 3px 6px 0px rgba(255, 168, 122, 0.35);
}
.filter-chip.active text {
  font-weight: 600;
  color: #ffffff;
}
.filter-chip:not(.active) {
  background: #ffffff;
  box-shadow: 0px 2px 4px 0px rgba(230, 198, 179, 0.2);
}
.filter-chip:not(.active) text {
  color: #808080;
}

/* ---- Month Section Title ---- */
.month-section {
  display: flex;
  align-items: flex-end;
  width: 670rpx;
  padding: 16rpx 0 8rpx;
  flex-shrink: 0;
}
.month-section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
}
.month-section-count {
  font-size: 26rpx;
  color: #999;
  margin-left: 16rpx;
  padding-bottom: 2rpx;
}

/* ---- Loading / Empty States ---- */
.load-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}
.load-state text {
  font-size: var(--clay-font-body);
  color: var(--clay-text-secondary);
}
.empty-state text {
  font-size: var(--clay-font-body);
  color: var(--clay-text-secondary);
}
.empty-upload-btn {
  background: var(--clay-primary);
  border-radius: 32rpx;
  box-shadow: 0px 4px 8px 0px rgba(255, 168, 122, 0.4);
  padding: 16rpx 48rpx;
}
.empty-upload-btn text {
  font-size: var(--clay-font-body);
  font-weight: 600;
  color: #ffffff;
}

/* ---- Card Grid (2-column, masonry-like) ---- */
.media-sections {
  width: 670rpx;
  flex-shrink: 0;
}

.card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  flex-shrink: 0;
}

/* Card base */
.media-card {
  width: 324rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

/* Card color variants */
.clay-card-pink {
  background: #f1dce2;
  box-shadow: 0px 5px 12px 0px rgba(241, 220, 226, 0.3);
}
.clay-card-blue {
  background: #dceaf1;
  box-shadow: 0px 5px 12px 0px rgba(220, 234, 241, 0.3);
}
.clay-card-beige {
  background: #f4e6d6;
  box-shadow: 0px 5px 12px 0px rgba(244, 230, 214, 0.3);
}
.clay-card-mint {
  background: #e2f1e6;
  box-shadow: 0px 5px 12px 0px rgba(226, 241, 230, 0.3);
}

/* Card image placeholder */
.media-card-image {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}
.media-card-image image {
  width: 100%;
  height: 100%;
  display: block;
}

/* Card title */
.media-card-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #665959;
  line-height: 1.3;
}

/* ---- FAB ---- */
.fab {
  display: none;
}
.fab-upload {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #ffa87a;
  box-shadow: 0px 6px 16px 0px rgba(255, 168, 122, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.fab-upload text {
  font-size: 60rpx;
  font-weight: 300;
  color: #ffffff;
  line-height: 1;
}