<!-- album_home.wxml - Claymorphism 首页 -->
<view class="page-home">

  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="home-nav">
    <text class="home-nav-title">宝宝成长日记</text>
    <view class="home-nav-actions">
      <view class="nav-btn-upload" bindtap="onUploadTap">
        <text class="nav-btn-plus">+</text>
      </view>
      <view class="nav-btn-profile" bindtap="goToSettings">
        <text class="nav-btn-emoji">👤</text>
      </view>
    </view>
  </view>

  <!-- Content -->
  <view class="clay-content">

    <!-- Baby Info Header -->
    <view class="baby-header-card" bindtap="onBabySelect">
      <view class="baby-header-avatar"><text>👶</text></view>
      <view class="baby-header-info">
        <text class="baby-header-name">{{currentBaby ? currentBaby.name : '选择宝宝'}} ✨</text>
        <text class="baby-header-age">{{babyAgeText}}</text>
      </view>
      <view class="baby-header-setting" catchtap="goToBabyProfile">
        <text>⚙</text>
      </view>
    </view>

    <!-- Month Filter -->
    <view class="month-filter">
      <view wx:for="{{filterOptions}}" wx:key="value"
        class="filter-chip {{item.active ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onFilterSelect"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- Loading -->
    <view wx:if="{{isLoading}}" class="load-state">
      <text>加载中...</text>
    </view>

    <!-- Empty -->
    <view wx:elif="{{isEmpty}}" class="empty-state">
      <text>暂无照片，上传第一张记录</text>
      <view class="empty-upload-btn" bindtap="onUploadTap">
        <text>上传照片</text>
      </view>
    </view>

    <!-- Media Cards -->
    <view wx:else class="media-sections">
      <view class="month-section">
        <text class="month-section-title">{{currentMonthLabel}}</text>
        <text class="month-section-count">{{mediaList.length}}张记录</text>
      </view>

      <view class="card-grid">
        <view wx:for="{{mediaList}}" wx:key="id"
          class="media-card clay-card-{{item.cardColor || 'pink'}}"
          data-id="{{item.id}}"
          bindtap="onMediaTap"
        >
          <view class="media-card-image">
            <image mode="aspectFill" src="{{item.thumbnailUrl || item.url}}" lazy-load></image>
          </view>
          <text class="media-card-title">{{item.title || '无标题'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Bottom Nav -->
  <bottom-nav current="home"></bottom-nav>

  <!-- FAB -->
  <view class="fab-upload" bindtap="onUploadTap">
    <text>+</text>
  </view>
</view>