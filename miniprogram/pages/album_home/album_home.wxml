<!-- album_home.wxml - Claymorphism 首页 -->
<wxs module="util">
var exports = {};
exports.avatarUrl = function(baby) {
  if (baby && baby.avatar && baby.avatar.indexOf('http') === 0) {
    return baby.avatar;
  }
  return '';
};
module.exports = exports;
</wxs>
<view class="page-home">

  <!-- Status Bar Spacer -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="home-nav">
    <text class="home-nav-title">宝宝成长日记</text>
    <view class="home-nav-spacer"></view>
  </view>

  <!-- Content (scroll-view for scroll events) -->
  <scroll-view class="clay-content" scroll-y bindscroll="onContentScroll" enable-flex>

    <!-- ===== Baby Info Header (双态折叠) ===== -->
    <view class="baby-header-container {{headerCollapsed ? 'collapsed' : 'expanded'}}">

      <!-- 展开态：完整信息卡片 -->
      <view class="baby-header-expanded {{headerCollapsed ? 'fade-out' : ''}}">
        <view class="baby-header-avatar">
          <image wx:if="{{util.avatarUrl(currentBaby)}}" class="header-avatar-image" src="{{util.avatarUrl(currentBaby)}}" mode="aspectFill"></image>
          <text wx:else>{{currentBaby ? (currentBaby.avatar || '👶') : '👶'}}</text>
        </view>
        <view class="baby-header-info">
          <text class="baby-header-name">{{currentBaby ? currentBaby.name : '选择宝宝'}} ✨</text>
          <text class="baby-header-age">{{babyAgeText}}</text>
        </view>
        <view class="baby-header-setting" catchtap="goToBabyProfile">
          <text>⚙</text>
        </view>
      </view>

      <!-- 折叠态：水平宝宝头像条 -->
      <view class="baby-header-collapsed {{headerCollapsed ? '' : 'fade-out'}}">
        <scroll-view class="baby-strip-scroll" scroll-x enable-flex>
          <view wx:for="{{babies}}" wx:key="id"
            class="baby-strip-item {{currentBabyId === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="onBabyStripTap"
          >
            <view class="strip-avatar" style="background-color: {{item.gender === 'male' ? '#dceaf1' : '#f1dce2'}};">
              <text>{{item.avatar || '👶'}}</text>
            </view>
          </view>
          <!-- 加号按钮 -->
          <view class="baby-strip-item strip-add-btn" bindtap="onAddBabyTap">
            <view class="strip-add-circle">
              <text>+</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- Month Filter Chips -->
    <view class="month-filter">
      <view wx:for="{{filterOptions}}" wx:key="value"
        class="filter-chip {{item.active ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onFilterSelect"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- Loading State -->
    <view wx:if="{{isLoading}}" class="load-state">
      <text>加载中...</text>
    </view>

    <!-- Empty State -->
    <view wx:elif="{{isEmpty}}" class="empty-state">
      <text>暂无照片，上传第一张记录</text>
      <view class="empty-upload-btn" bindtap="onUploadTap">
        <text>上传照片</text>
      </view>
    </view>

    <!-- Media Cards -->
    <view wx:else class="media-sections">
      <!-- Month title with count -->
      <view class="month-section">
        <text class="month-section-title">{{currentMonthLabel}}</text>
        <text class="month-section-count">{{mediaList.length}}张记录</text>
      </view>

      <!-- 2-column card grid -->
      <view class="card-grid">
        <view wx:for="{{mediaList}}" wx:key="id"
          class="media-card clay-card-{{item.cardColor || 'pink'}} lazy-media-card"
          style="min-height: {{item._height || 250}}rpx;"
          data-id="{{item.id}}"
          bindtap="onMediaTap"
        >
          <!-- Lazy loaded image: placeholder until visible -->
          <view class="media-card-image" style="height: {{item._imgHeight || 180}}rpx;">
            <view wx:if="{{visibleIds[item.id]}}" class="media-card-img-wrapper">
              <image mode="aspectFill" src="{{item.thumbnailUrl || item.url}}"></image>
            </view>
            <view wx:else class="media-card-placeholder">
              <view class="placeholder-shimmer"></view>
            </view>
          </view>
          <text class="media-card-title">{{item.title || '无标题'}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Bottom Navigation -->
  <bottom-nav current="journey"></bottom-nav>

  <!-- FAB Upload Button -->
  <view class="fab-upload" bindtap="onUploadTap">
    <text>+</text>
  </view>
</view>