<!-- album_home.wxml - 成长 v2 (瀑布流 + 年龄段筛选) -->
<wxs module="util">
var exports = {};
exports.formatDate = function(dateStr) {
  if (!dateStr) return '';
  var parts = dateStr.split('-');
  if (parts.length < 3) return dateStr;
  return parts[1] + '.' + parts[2];
};
module.exports = exports;
</wxs>

<view class="page-home">

  <!-- Status Bar Spacer -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="home-nav">
    <text class="home-nav-title">宝宝成长日记</text>
    <view class="home-nav-spacer"></view>
  </view>

  <!-- Content Area -->
  <scroll-view class="clay-content" scroll-y bindscroll="onContentScroll" enable-flex>

    <!-- Age Filter Chips -->
    <view class="age-filter">
      <view
        wx:for="{{filterOptions}}"
        wx:key="value"
        class="filter-chip {{currentFilter === (item.value || '全部') ? 'active' : ''}}"
        data-value="{{item.value || '全部'}}"
        bindtap="onFilterSelect"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- Loading State -->
    <view wx:if="{{isLoading}}" class="load-state">
      <text>加载中...</text>
    </view>

    <!-- Empty State -->
    <view wx:elif="{{isEmpty}}" class="empty-state">
      <text>暂无成长记录</text>
      <view class="empty-upload-btn" bindtap="goToRecord">
        <text>记录成长瞬间</text>
      </view>
    </view>

    <!-- Waterfall Sections -->
    <view wx:else class="waterfall-sections">

      <view wx:for="{{sections}}" wx:for-item="section" wx:key="title" class="milestone-section">

        <!-- Milestone Header -->
        <view class="milestone-header">
          <text class="milestone-icon">{{section.icon}}</text>
          <view class="milestone-info">
            <text class="milestone-title">{{section.title}}</text>
            <text class="milestone-meta">{{section.dateLabel}} · {{section.ageLabel}}</text>
          </view>
          <view class="milestone-separator"></view>
        </view>

        <!-- 2-Column Waterfall -->
        <view class="waterfall-grid">
          <!-- Left Column -->
          <view class="waterfall-col">
            <view wx:for="{{section.items}}" wx:key="id"
              wx:if="{{item._col === 'left'}}"
              class="media-card"
              style="height: {{item._height}}rpx; background-color: {{item.cardColor}};"
              data-id="{{item.id}}"
              bindtap="onMediaTap"
            >
              <!-- Media Placeholder -->
              <view class="media-bg" style="background-color: {{item.cardColor}};"></view>

              <!-- Media Type Icon -->
              <text class="media-type-icon">{{item.mediaType === 'video' ? '🎬' : '📷'}}</text>

              <!-- Date Overlay -->
              <text class="media-date">{{util.formatDate(item.captureDate)}}</text>

              <!-- Video Duration Badge -->
              <view wx:if="{{item.mediaType === 'video' && item.duration}}" class="video-badge">
                <text>▶</text>
                <text>{{item.duration}}</text>
              </view>

              <!-- Menu Button (Author only) -->
              <view wx:if="{{isAuthorMode}}" class="card-menu" data-id="{{item.id}}" catchtap="onMenuTap">
                <text>⋮</text>
              </view>
            </view>
          </view>

          <!-- Right Column -->
          <view class="waterfall-col">
            <view wx:for="{{section.items}}" wx:key="id"
              wx:if="{{item._col === 'right'}}"
              class="media-card"
              style="height: {{item._height}}rpx; background-color: {{item.cardColor}};"
              data-id="{{item.id}}"
              bindtap="onMediaTap"
            >
              <view class="media-bg" style="background-color: {{item.cardColor}};"></view>
              <text class="media-type-icon">{{item.mediaType === 'video' ? '🎬' : '📷'}}</text>
              <text class="media-date">{{util.formatDate(item.captureDate)}}</text>

              <view wx:if="{{item.mediaType === 'video' && item.duration}}" class="video-badge">
                <text>▶</text>
                <text>{{item.duration}}</text>
              </view>

              <view wx:if="{{isAuthorMode}}" class="card-menu" data-id="{{item.id}}" catchtap="onMenuTap">
                <text>⋮</text>
              </view>
            </view>
          </view>
        </view>

      </view>
    </view>

  </scroll-view>

  <!-- Bottom Navigation -->
  <bottom-nav current="growth"></bottom-nav>

</view>