<!-- album_home.wxml - 成长 v2 (瀑布流 + 年龄段筛选) -->
<view class="page-home">

  <!-- Status Bar Spacer -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="home-nav">
    <view class="home-nav-left">
      <text class="home-nav-title">宝宝成长日记</text>
    </view>
    <view class="baby-selector" bindtap="toggleBabyPicker">
      <text class="baby-selector-value">{{currentBaby.name || '选择宝宝'}}</text>
      <text class="baby-selector-arrow">{{showBabyPicker ? '▲' : '▼'}}</text>
    </view>
  </view>

  <!-- Baby Picker Dropdown -->
  <view wx:if="{{showBabyPicker && babies.length > 0}}" class="baby-picker-overlay" catchtap="toggleBabyPicker">
    <view class="baby-picker-dropdown">
      <view
        wx:for="{{babies}}"
        wx:key="id"
        wx:for-item="baby"
        class="baby-picker-item {{baby.id === currentBabyId ? 'baby-picker-item-active' : ''}}"
        data-id="{{baby.id}}"
        data-name="{{baby.name}}"
        catchtap="onBabySelect"
      >
        <text class="baby-picker-name">{{baby.name}}</text>
        <text wx:if="{{baby.id === currentBabyId}}" class="baby-picker-check">✓</text>
      </view>
    </view>
  </view>

  <!-- Content Area (Skyline: 不使用 enable-flex) -->
  <scroll-view class="clay-content" scroll-y bindscroll="onContentScroll">

    <!-- Age Filter Chips -->
    <view class="age-filter">
      <view
        wx:for="{{filterOptions}}"
        wx:key="value"
        class="filter-chip {{currentFilter === (item.value || '全部') ? 'active' : ''}}"
        data-value="{{item.value || '全部'}}"
        bindtap="onFilterSelect"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- Loading State -->
    <view wx:if="{{isLoading}}" class="load-state">
      <text>加载中...</text>
    </view>

    <!-- Empty State -->
    <view wx:elif="{{isEmpty}}" class="empty-state">
      <text>暂无成长记录</text>
      <view class="empty-upload-btn" bindtap="goToRecord">
        <text>记录成长瞬间</text>
      </view>
    </view>

    <!-- Waterfall Sections -->
    <view wx:elif="{{!isLoading && !isEmpty}}" class="waterfall-sections">

      <view wx:for="{{sections}}" wx:for-item="section" wx:key="title" class="milestone-section">

        <!-- Milestone Header -->
        <view class="milestone-header">
          <text class="milestone-icon">{{section.icon}}</text>
          <view class="milestone-info">
            <text class="milestone-title">{{section.title}}</text>
            <text class="milestone-meta">{{section.dateLabel}} · {{section.ageLabel}}</text>
          </view>
          <view class="milestone-separator"></view>
        </view>

        <!-- 2-Column Waterfall (Skyline: 使用 view wx:for 替代 block wx:for) -->
        <view class="waterfall-grid">
          <!-- Left Column -->
          <view class="waterfall-col">
            <view
              wx:for="{{section.leftItems}}"
              wx:key="id"
              wx:for-item="card"
              class="media-card"
              style="height: {{card._height}}rpx; background-color: {{card.cardColor}};"
              data-id="{{card.id}}"
              bindtap="onMediaTap"
            >
              <image wx:if="{{card.thumbnailUrl}}" class="media-thumb" src="{{card.thumbnailUrl}}" mode="aspectFill"></image>
              <text wx:else class="media-type-icon">{{card.mediaType === 'video' ? '🎬' : '📷'}}</text>
              <text class="media-date">{{card.displayDate}}</text>

              <view wx:if="{{card.mediaType === 'video' && card.duration}}" class="video-badge">
                <text>▶</text>
                <text>{{card.duration}}</text>
              </view>

              <view wx:if="{{isAuthorMode}}" class="card-menu" data-id="{{card.id}}" catchtap="onMenuTap">
                <text>⋮</text>
              </view>
            </view>
          </view>

          <!-- Right Column -->
          <view class="waterfall-col">
            <view
              wx:for="{{section.rightItems}}"
              wx:key="id"
              wx:for-item="card"
              class="media-card"
              style="height: {{card._height}}rpx; background-color: {{card.cardColor}};"
              data-id="{{card.id}}"
              bindtap="onMediaTap"
            >
              <image wx:if="{{card.thumbnailUrl}}" class="media-thumb" src="{{card.thumbnailUrl}}" mode="aspectFill"></image>
              <text wx:else class="media-type-icon">{{card.mediaType === 'video' ? '🎬' : '📷'}}</text>
              <text class="media-date">{{card.displayDate}}</text>

              <view wx:if="{{card.mediaType === 'video' && card.duration}}" class="video-badge">
                <text>▶</text>
                <text>{{card.duration}}</text>
              </view>

              <view wx:if="{{isAuthorMode}}" class="card-menu" data-id="{{card.id}}" catchtap="onMenuTap">
                <text>⋮</text>
              </view>
            </view>
          </view>
        </view>

      </view>
    </view>

  </scroll-view>

  <!-- Bottom Navigation -->
  <bottom-nav current="growth"></bottom-nav>

</view>