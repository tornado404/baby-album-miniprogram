<!-- tech_validate.wxml - 技术可行性验证页面 -->

<!-- 顶部导航栏 -->
<van-nav-bar title="技术验证" left-arrow bind:click-left="goHome" />

<!-- 主内容区 -->
<view class="container">

  <!-- 页面说明 -->
  <view class="section">
    <view class="section-title">技术栈兼容性验证</view>
    <view class="section-desc">验证 Skyline + glass-easel + Vant Weapp 组合是否正常工作</view>
  </view>

  <!-- 测试结果列表 -->
  <view class="section">
    <view class="section-title">验证结果</view>
    <van-cell-group>
      <block wx:for="{{testResults}}" wx:key="name">
        <van-cell
          title="{{item.name}}"
          value="{{item.status}}"
          icon="{{item.status === 'pass' ? 'success' : item.status === 'fail' ? 'cross' : 'clock-o'}}"
          label="{{item.message}}"
        />
      </block>
    </van-cell-group>
  </view>

  <!-- 瀑布流布局测试 -->
  <view class="section">
    <view class="section-title">瀑布流布局测试</view>
    <view class="masonry-container">
      <view class="masonry-row">
        <block wx:for="{{masonryList}}" wx:key="id">
          <view class="masonry-item" style="margin-bottom: {{itemGap}}px;">
            <van-image
              width="100%"
              height="{{item.height}}"
              src="{{item.url}}"
              fit="cover"
              lazy-load
            />
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- slot插槽测试 -->
  <view class="section">
    <view class="section-title">slot插槽测试</view>
    <view class="slot-test-container">
      <van-button type="primary" size="small">测试按钮</van-button>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="section">
    <van-button type="default" block bind:click="revalidate">
      <van-loading wx:if="{{isLoading}}" /> 重新验证
    </van-button>
  </view>

</view>