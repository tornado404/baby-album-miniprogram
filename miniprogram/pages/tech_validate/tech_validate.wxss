/* tech_validate.wxss - 技术验证页面样式 */

.container {
  padding: 16px;
  background-color: #f7f8fa;
  min-height: 100vh;
}

.section {
  margin-bottom: 24px;
  background-color: #ffffff;
  border-radius: 8px;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #323233;
  margin-bottom: 12px;
}

.section-desc {
  font-size: 14px;
  color: #969799;
  margin-bottom: 16px;
}

/* 瀑布流测试样式 */
.masonry-container {
  padding: 8px 0;
}

.masonry-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-left: -4px;
  margin-right: -4px;
}

.masonry-item {
  width: calc(50% - 4px);
  margin-left: 2px;
  margin-right: 2px;
  border-radius: 4px;
  overflow: hidden;
  background-color: #f7f8fa;
}

/* slot测试容器 */
.slot-test-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24px;
  background-color: #f7f8fa;
  border-radius: 4px;
}