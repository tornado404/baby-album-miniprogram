/* tech_validate.wxss - 技术验证页面样式 */

.container {
  padding: 16px;
  background-color: #f7f8fa;
  min-height: 100vh;
}

.section {
  margin-bottom: 24px;
  background-color: #ffffff;
  border-radius: 8px;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #323233;
  margin-bottom: 12px;
}

.section-desc {
  font-size: 14px;
  color: #969799;
  margin-bottom: 16px;
}

/* 瀑布流测试样式 */
.masonry-container {
  padding: 8px 0;
}

.masonry-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-left: -4px;
  margin-right: -4px;
}

.masonry-item {
  width: calc(50% - 4px);
  margin-left: 2px;
  margin-right: 2px;
  border-radius: 4px;
  overflow: hidden;
  background-color: #f7f8fa;
}

/* 导航栏 */
.nav-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #ffffff;
  border-bottom: 1px solid #ebedf0;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  height: 46px;
  padding: 0 16px;
}

.nav-bar-left {
  flex-shrink: 0;
}

.nav-bar-arrow {
  font-size: 18px;
  color: #323233;
}

.nav-bar-title {
  flex: 1;
  text-align: center;
  font-size: 16px;
  font-weight: 500;
  color: #323233;
}

/* 测试结果 */
.test-result-item {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background-color: #ffffff;
  border-bottom: 1px solid #ebedf0;
}

.test-result-name {
  flex: 1;
  font-size: 14px;
  color: #323233;
}

.test-result-status {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
}

.test-result-status.pass {
  background-color: #e8f7ef;
  color: #07c160;
}

.test-result-status.fail {
  background-color: #fef0f0;
  color: #ee0a24;
}

.test-result-message {
  font-size: 12px;
  color: #969799;
  margin-left: 8px;
}

/* 按钮 */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 4px;
  padding: 8px 16px;
  font-size: 14px;
}

.btn-block {
  display: flex;
  width: 100%;
}
