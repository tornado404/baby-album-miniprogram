<!-- onboarding.wxml - 登录引导页（Onboarding）Claymorphism 风格 -->
<view class="page-onboarding">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;">
    <text class="status-time">9:41</text>
  </view>

  <!-- Main Content -->
  <view class="onboarding-content">

    <!-- Top Spacer -->
    <view class="spacer-top"></view>

    <!-- Logo Circle -->
    <view class="onboarding-logo">
      <text class="logo-emoji">👶</text>
    </view>

    <!-- Spacer after logo -->
    <view style="height: 64rpx;"></view>

    <!-- App Name -->
    <text class="onboarding-title">宝宝成长相册</text>

    <!-- Spacer after title -->
    <view style="height: 24rpx;"></view>

    <!-- Subtitle -->
    <text class="onboarding-subtitle">记录宝宝每一个成长瞬间</text>

    <!-- Spacer after subtitle -->
    <view style="height: 16rpx;"></view>

    <!-- Feature Tags -->
    <text class="onboarding-tags">照片 · 视频 · 3D模型 · 成长轨迹</text>

    <!-- Decorative Illustration Area -->
    <view class="illustration-area">
      <view class="deco-circle deco-circle-1"></view>
      <view class="deco-circle deco-circle-2"></view>
      <view class="deco-circle deco-circle-3"></view>
    </view>

    <!-- Bottom Spacer (pushes button down) -->
    <view class="spacer-bottom"></view>

    <!-- Bottom Section -->
    <view class="onboarding-bottom">

      <!-- Loading State -->
      <view wx:if="{{authState === 'loading'}}" class="loading-container">
        <view class="loading-spinner"></view>
        <text class="loading-text">正在获取你的信息...</text>
      </view>

      <!-- Profile Setup (after login, before entering app) -->
      <view wx:elif="{{authState === 'profile'}}" class="profile-setup">
        <view class="profile-avatar-area">
          <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{avatarUrl}}" class="profile-avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
            <text wx:else class="avatar-placeholder">👤</text>
          </button>
          <text class="avatar-hint">点击设置头像</text>
        </view>
        <view class="profile-name-area">
          <text class="profile-label">昵称</text>
          <input class="profile-input" type="nickname" placeholder="你的微信昵称" bindinput="onNicknameInput" bindblur="onNicknameBlur" />
        </view>
        <view class="profile-confirm-btn" bindtap="onConfirmProfile" hover-class="login-btn-hover">
          <text class="profile-confirm-text">进入宝宝成长相册</text>
        </view>
      </view>

      <!-- Login Button / Retry -->
      <view wx:if="{{authState === 'idle' || authState === 'error'}}" class="login-btn-wrapper">
        <view class="login-btn {{hasAgreed ? '' : 'login-btn-disabled'}}" bindtap="onLoginTap" hover-class="{{hasAgreed ? 'login-btn-hover' : ''}}">
          <text wx:if="{{authState === 'idle'}}" class="login-btn-text">微信一键登录</text>
          <text wx:elif="{{authState === 'error'}}" class="login-btn-text">重新授权</text>
        </view>

        <!-- Error Message -->
        <text wx:if="{{authState === 'error'}}" class="error-text">{{errorMsg}}</text>
      </view>

      <!-- Privacy Agreement -->
      <view class="privacy-row">
        <view class="privacy-checkbox {{hasAgreed ? 'privacy-checkbox-checked' : ''}}" bindtap="onPrivacyTap">
          <text wx:if="{{hasAgreed}}" class="checkbox-icon">✓</text>
        </view>
        <text class="privacy-text">我已阅读并同意</text>
        <text class="privacy-link" data-url="/pages/privacy_agreement/privacy_agreement?type=agreement" bindtap="onPolicyLinkTap">《用户服务协议》</text>
        <text class="privacy-text">和</text>
        <text class="privacy-link" data-url="/pages/privacy_agreement/privacy_agreement?type=privacy" bindtap="onPolicyLinkTap">《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- Safe Area Bottom -->
  <view class="safe-area-bottom"></view>
</view>
