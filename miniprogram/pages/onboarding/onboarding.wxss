/* onboarding.wxss - 登录引导页 Claymorphism 风格 */

.page-onboarding {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fffbf8;
}

/* ---- Status Bar ---- */
.status-bar {
  display: flex;
  align-items: flex-start;
  padding: 0 24px;
  box-sizing: border-box;
  flex-shrink: 0;
  background: #fffbf8;
  width: 100%;
}

.status-time {
  font-size: 15px;
  font-weight: 600;
  color: #4a4a4a;
  font-family: "Inter", -apple-system, sans-serif;
  line-height: normal;
}

/* ---- Main Content ---- */
.onboarding-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
  justify-content: center;
}

/* ---- Spacers ---- */
.spacer-top {
  flex: 1;
  min-height: 40rpx;
  max-height: 200rpx;
}

.spacer-bottom {
  flex: 1;
  min-height: 60rpx;
  max-height: 240rpx;
}

/* ---- Logo Circle ---- */
.onboarding-logo {
  width: 320rpx;
  height: 320rpx;
  border-radius: 160rpx;
  background: #f1dce2;
  box-shadow: 0px 8px 20px 0px rgba(241, 220, 226, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.logo-emoji {
  font-size: 128rpx;
  color: #806680;
  line-height: normal;
}

/* ---- Titles ---- */
.onboarding-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #4a4a4a;
  text-align: center;
  line-height: 1.3;
}

.onboarding-subtitle {
  font-size: 32rpx;
  font-weight: 500;
  color: #999;
  text-align: center;
  line-height: 1.4;
}

.onboarding-tags {
  font-size: 26rpx;
  font-weight: 400;
  color: #b2a699;
  text-align: center;
  line-height: 1.4;
}

/* ---- Decorative Illustration ---- */
.illustration-area {
  position: relative;
  width: 200rpx;
  height: 120rpx;
  margin-top: 32rpx;
  flex-shrink: 0;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
}

.deco-circle-1 {
  width: 48rpx;
  height: 48rpx;
  background: #dceaf1;
  top: 20rpx;
  left: 10rpx;
  box-shadow: 0px 3px 8px 0px rgba(220, 234, 241, 0.4);
}

.deco-circle-2 {
  width: 36rpx;
  height: 36rpx;
  background: #e2f1e6;
  top: 0rpx;
  left: 90rpx;
  box-shadow: 0px 3px 8px 0px rgba(226, 241, 230, 0.4);
}

.deco-circle-3 {
  width: 40rpx;
  height: 40rpx;
  background: #f4e6d6;
  top: 40rpx;
  right: 10rpx;
  box-shadow: 0px 3px 8px 0px rgba(244, 230, 214, 0.4);
}

/* ---- Bottom Section ---- */
.onboarding-bottom {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  padding-bottom: 20rpx;
}

/* ---- Login Button ---- */
.login-btn-wrapper {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 480rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: #ffa87a;
  box-shadow: 0px 4px 10px 0px rgba(255, 168, 122, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.login-btn-hover {
  opacity: 0.88;
  transform: scale(0.97);
}

.login-btn-disabled {
  opacity: 0.5;
  box-shadow: none;
}

.login-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  line-height: normal;
}

/* ---- Loading State ---- */
.loading-container {
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 168, 122, 0.2);
  border-top-color: #ffa87a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 30rpx;
  color: #999;
  font-weight: 500;
}

/* ---- Error State ---- */
.error-text {
  font-size: 24rpx;
  color: #ee0a24;
  margin-top: 16rpx;
  text-align: center;
}

/* ---- Privacy Agreement ---- */
.privacy-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  flex-wrap: wrap;
  padding: 0 40rpx;
}

.privacy-checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
  background: #fff;
}

.privacy-checkbox-checked {
  background: #ffa87a;
  border-color: #ffa87a;
}

.checkbox-icon {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 700;
  line-height: normal;
}

.privacy-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
}

.privacy-link {
  font-size: 22rpx;
  color: #ffa87a;
  line-height: 1.6;
}

/* ---- Safe Area Bottom ---- */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
  flex-shrink: 0;
}
