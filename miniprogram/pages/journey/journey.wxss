.page-journey { min-height: 100vh; display: flex; flex-direction: column; background: #fffbf8; }
.status-bar { flex-shrink: 0; }

/* Nav Bar */
.journey-nav { display: flex; align-items: center; justify-content: space-between; height: 104rpx; padding: 0 32rpx; flex-shrink: 0; }
.journey-nav-title { font-size: 36rpx; font-weight: 700; color: #4a4a4a; }
.journey-share-btn { height: 64rpx; padding: 0 32rpx; border-radius: 32rpx; background: #ffa87a; display: flex; align-items: center; justify-content: center; }
.journey-share-btn text { font-size: 26rpx; font-weight: 600; color: #ffffff; }

/* Baby Header */
.baby-header { display: flex; align-items: center; gap: 24rpx; padding: 24rpx 32rpx; background: #ffffff; margin: 0 24rpx 16rpx; border-radius: 32rpx; box-shadow: 0px 4px 12px rgba(230,198,179,0.2); }
.baby-header-avatar { width: 88rpx; height: 88rpx; border-radius: 44rpx; background: #f1dce2; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.baby-header-avatar text { font-size: 44rpx; color: #806680; }
.baby-header-name { font-size: 34rpx; font-weight: 700; color: #4a4a4a; display: block; }
.baby-header-age { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }

/* Milestone Row */
.milestone-row { display: flex; padding: 16rpx 32rpx; white-space: nowrap; flex-shrink: 0; }
.milestone-dot { display: inline-flex; width: 72rpx; height: 72rpx; border-radius: 36rpx; background: #ffffff; margin-right: 16rpx; align-items: center; justify-content: center; box-shadow: 0px 2px 6px rgba(230,198,179,0.2); }
.milestone-dot-icon { font-size: 32rpx; }

/* Loading / Empty */
.load-state { flex: 1; display: flex; align-items: center; justify-content: center; }
.empty-state { padding: 200rpx 0; display: flex; flex-direction: column; align-items: center; gap: 16rpx; font-size: 28rpx; color: #999; }
.empty-hint { font-size: 24rpx; color: #ccc; }

/* Timeline */
.timeline-scroll { flex: 1; }
.timeline-inner { padding: 0 24rpx 200rpx; }
.month-group { margin-bottom: 32rpx; }
.month-title { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; padding-left: 8rpx; font-size: 32rpx; font-weight: 700; color: #4a4a4a; }
.month-count { font-size: 24rpx; font-weight: 400; color: #999; }
.month-cards { display: flex; flex-wrap: wrap; gap: 16rpx; }

.timeline-card { width: calc(50% - 8rpx); background: #ffffff; border-radius: 24rpx; overflow: hidden; box-shadow: 0px 3px 8px rgba(230,198,179,0.18); }
.tcard-img { width: 100%; height: 180rpx; display: flex; align-items: center; justify-content: center; }
.tcard-img text { font-size: 48rpx; color: #998080; }
.tcard-info { padding: 16rpx; }
.tcard-title { font-size: 26rpx; font-weight: 600; color: #4a4a4a; display: block; margin-bottom: 8rpx; }
.tcard-loc { font-size: 22rpx; color: #999; display: block; margin-bottom: 4rpx; }
.tcard-tag { font-size: 20rpx; color: #806666; background: #f9f0e9; padding: 4rpx 12rpx; border-radius: 16rpx; display: inline-block; margin-bottom: 4rpx; }
.tcard-moment { font-size: 24rpx; color: #665959; font-weight: 500; display: block; }