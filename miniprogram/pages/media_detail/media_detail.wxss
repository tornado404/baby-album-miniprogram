/* media_detail.wxss - 媒体详情页样式 */

.container {
  min-height: 100vh;
  background-color: #000000;
  position: relative;
}

.nav-bar-transparent {
  background-color: transparent;
  color: #ffffff;
}

.loading-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
}

.preview-container {
  width: 100%;
  height: calc(100vh - 120px);
}

.media-swiper {
  width: 100%;
  height: 100%;
}

.media-swiper van-image {
  width: 100%;
  height: 100%;
}

.image-container {
  width: 100%;
  height: 100%;
  transform-origin: center center;
}

.info-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  background-color: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  color: #ffffff;
  z-index: 100;
}

.info-content {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.media-title {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.media-date {
  font-size: 14px;
  opacity: 0.8;
  margin-bottom: 2px;
}

.media-age {
  font-size: 12px;
  opacity: 0.6;
}

.info-actions {
  display: flex;
  gap: 16px;
  padding-left: 16px;
}

.info-actions van-icon {
  font-size: 24px;
  color: #ffffff;
}