/* media_detail.wxss - 内容详情页 精确 Figma 还原 */

.page-detail {
  min-height: 100vh;
  background: #f9f0e9;
  display: flex;
  flex-direction: column;
}

.status-bar {
  flex-shrink: 0;
}

/* ---- Navigation Bar (Figma 精确) ---- */
.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 104rpx;
  padding: 0 24rpx 0 12rpx;
  flex-shrink: 0;
  background: #f9f0e9;
}

.nav-btn-white {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0px 2px 4px 0px rgba(230, 198, 179, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-btn-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
}

.nav-title-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
}

.nav-menu-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #4a4a4a;
  letter-spacing: 2rpx;
}

/* ---- Loading ---- */
.loading-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-ring {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255,168,122,0.2);
  border-top-color: #ffa87a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ---- Content Area ---- */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

/* ---- Main Image (Figma: 粉色背景 圆角24px) ---- */
.main-image-wrap {
  width: 288rpx;
  height: 680rpx;
  background: #f1dce2;
  border-radius: 48rpx;
  box-shadow: 0px 8px 24px 0px rgba(241, 220, 226, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 0 auto;
  overflow: hidden;
}

.main-image {
  width: 100%;
  height: 100%;
  display: block;
}

.main-video {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.main-image-placeholder {
  font-size: 144rpx;
  color: #998080;
}

/* ---- Info Card (Figma: 白色圆角20px 阴影) ---- */
.info-card {
  width: 670rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0px 4px 12px 0px rgba(230, 198, 179, 0.25);
  padding: 40rpx;
  margin-top: 40rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

/* Title Row */
.info-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56rpx;
}

.info-title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a4a4a;
}

.milestone-badge {
  height: 48rpx;
  background: #ffa87a;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.milestone-badge text {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
}

/* Date */
.info-date {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* Separator */
.info-separator {
  width: 100%;
  height: 2rpx;
  background: #e6e6e6;
  margin: 24rpx 0;
}

/* Description */
.info-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 44rpx;
}

/* Tags */
.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.info-tag {
  height: 44rpx;
  background: #f9f0e9;
  border-radius: 22rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
  color: #806666;
  display: flex;
  align-items: center;
}

/* ---- Action Sheet ---- */
.actions-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 300;
}

.actions-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fffbf8;
  border-radius: 36rpx 36rpx 0 0;
  z-index: 301;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0px -6px 20px 0px rgba(230, 198, 179, 0.25);
}

.actions-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 40rpx;
  font-size: 30rpx;
  color: #4a4a4a;
  font-weight: 500;
  border-bottom: 1rpx solid #f4e6d6;
}

.actions-item.danger {
  color: #ee0a24;
}

.actions-icon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}

.actions-cancel {
  padding: 28rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999;
  font-weight: 500;
  margin: 8rpx 20rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0px 2px 6px 0px rgba(230, 198, 179, 0.15);
}