<!-- media_detail.wxml - Claymorphism 风格媒体详情页 -->
<view class="page-detail">

  <!-- Navigation Bar (Claymorphism) -->
  <view class="detail-nav" style="padding-top: {{safeTop}}px;">
    <view class="detail-nav-inner">
      <view class="detail-nav-btn" bindtap="goBack">
        <text>←</text>
      </view>
      <text class="detail-nav-title">{{media ? media.title || '照片详情' : '照片详情'}}</text>
      <view class="detail-nav-btn" bindtap="onActionsTap">
        <text class="detail-nav-more">⋯</text>
      </view>
    </view>
  </view>

  <!-- Loading State -->
  <view wx:if="{{isLoading}}" class="detail-loading">
    <view class="loading-ring"></view>
  </view>

  <!-- Image Preview Area -->
  <view wx:else class="preview-wrapper">
    <swiper
      class="media-swiper"
      current="{{currentIndex}}"
      bindchange="onSwiperChange"
      circular="{{false}}"
    >
      <block wx:for="{{mediaList}}" wx:key="id">
        <swiper-item>
          <view
            class="image-wrap"
            style="transform: scale({{index === currentIndex ? scale : 1}});"
            catchtouchstart="onTouchStart"
            catchtouchmove="onTouchMove"
            catchtouchend="onTouchEnd"
          >
            <image
              class="preview-image"
              mode="aspectFit"
              src="{{item.url}}"
              show-menu-by-longpress
              lazy-load
            />
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <!-- Info Bar (Claymorphism style) -->
  <view wx:if="{{media}}" class="detail-info-bar">
    <view class="info-left">
      <text class="info-title">{{media.title || '无标题'}}</text>
      <view class="info-meta">
        <text class="info-date">{{media.captureDate}}</text>
        <text wx:if="{{babyAgeText}}" class="info-age">{{babyAgeText}}</text>
      </view>
    </view>
  </view>

  <!-- Actions Sheet (Claymorphism) -->
  <view wx:if="{{showActions}}" class="actions-overlay" bindtap="onActionsCancel"></view>
  <view wx:if="{{showActions}}" class="actions-sheet">
    <block wx:for="{{actions}}" wx:key="name">
      <view
        class="actions-item {{item.danger ? 'danger' : ''}}"
        bindtap="onActionsSelect"
        data-index="{{index}}"
      >
        <text class="actions-icon">{{item.icon}}</text>
        <text>{{item.name}}</text>
      </view>
    </block>
    <view class="actions-cancel" bindtap="onActionsCancel">
      <text>取消</text>
    </view>
  </view>

</view>