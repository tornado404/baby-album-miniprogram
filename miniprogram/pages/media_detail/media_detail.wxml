<!-- media_detail.wxml - 内容详情页 精确 Figma 还原 -->
<view class="page-detail" style="background-color: #f9f0e9;">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="detail-nav">
    <view class="nav-btn-white" bindtap="goBack">
      <text class="nav-btn-text">←</text>
    </view>
    <text class="nav-title-text">成长记录</text>
    <view class="nav-btn-white" bindtap="onActionsTap">
      <text class="nav-menu-text">•••</text>
    </view>
  </view>

  <!-- Loading -->
  <view wx:if="{{isLoading}}" class="loading-state">
    <view class="loading-ring"></view>
  </view>

  <!-- Content Area -->
  <scroll-view wx:else class="content-area" scroll-y enable-flex>

    <!-- Main Media -->
    <view class="main-image-wrap">
      <video wx:if="{{media && media.type === 'video' && media.cosUrl}}" class="main-video" src="{{media.cosUrl}}" controls autoplay="{{false}}" show-center-play-btn="{{true}}" object-fit="contain"></video>
      <image wx:elif="{{media && media.cosUrl}}" class="main-image" src="{{media.cosUrl}}" mode="aspectFit" show-menu-by-longpress></image>
      <text wx:else class="main-image-placeholder">📷✨</text>
    </view>

    <!-- Info Section Card -->
    <view wx:if="{{media}}" class="info-card">
      <!-- Title Row -->
      <view class="info-title-row">
        <text class="info-title-text">{{media.title || '成长记录'}}</text>
        <view wx:if="{{media.milestone}}" class="milestone-badge">
          <text>里程碑</text>
        </view>
      </view>

      <!-- Date + Age -->
      <text class="info-date">{{media.captureDate || ''}} · {{babyAgeText}}</text>

      <!-- Separator -->
      <view class="info-separator"></view>

      <!-- Description -->
      <text class="info-desc">{{media.moment || media.title || '记录宝宝的美好时刻'}}</text>

      <!-- Tags -->
      <view wx:if="{{media.tags && media.tags.length > 0}}" class="info-tags">
        <text wx:for="{{media.tags}}" wx:key="*this" class="info-tag">{{item}}</text>
      </view>
    </view>

  </scroll-view>

  <!-- Action Sheet -->
  <view wx:if="{{showActions}}" class="actions-overlay" bindtap="onActionsCancel"></view>
  <view wx:if="{{showActions}}" class="actions-sheet">
    <view wx:for="{{actions}}" wx:key="name" class="actions-item {{item.danger ? 'danger' : ''}}" bindtap="onActionsSelect" data-index="{{index}}">
      <text class="actions-icon">{{item.icon}}</text>
      <text>{{item.name}}</text>
    </view>
    <view class="actions-cancel" bindtap="onActionsCancel">
      <text>取消</text>
    </view>
  </view>

</view>