/* settings.wxss - 我的/设置页面 Claymorphism 样式 */

.page-settings {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--clay-bg, #fffbf8);
}

.status-bar {
  flex-shrink: 0;
}

/* Navigation Bar */
.settings-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 104rpx;
  flex-shrink: 0;
}

.nav-title-centered {
  font-size: var(--clay-font-xxl);
  font-weight: 700;
  color: var(--clay-text-primary);
}

/* Content Area */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
  padding: 40rpx 0 160rpx;
  width: 750rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

/* User Card */
.user-card {
  width: 670rpx;
  height: 200rpx;
  background: var(--clay-card-white);
  border-radius: 48rpx;
  box-shadow: var(--clay-shadow-card);
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 32rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.user-avatar {
  width: 96rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: var(--clay-avatar-lavender);
  box-shadow: 0px 4px 10px 0px rgba(221, 214, 234, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-avatar text {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: var(--clay-font-xxl);
  font-weight: 700;
  color: var(--clay-text-primary);
}

.user-record {
  font-size: var(--clay-font-md);
  color: var(--clay-text-secondary);
  font-weight: 500;
}

.achievement-badge {
  width: 112rpx;
  height: 110rpx;
  background: var(--clay-card-beige);
  border-radius: 32rpx;
  box-shadow: 0px 4px 8px 0px rgba(244, 230, 214, 0.35);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  margin: 16rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.badge-icon {
  font-size: 44rpx;
}

.badge-count {
  font-size: var(--clay-font-sm);
  font-weight: 600;
  color: var(--clay-text-dark-warm);
  text-align: center;
}

/* Stats Container */
.stats-container {
  display: flex;
  gap: 28rpx;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 670rpx;
}

.stat-item {
  width: 204rpx;
  background: var(--clay-card-white);
  border-radius: var(--clay-radius-lg);
  box-shadow: 0px 3px 6px 0px rgba(230, 198, 179, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
  flex-shrink: 0;
}

.stat-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
}

.stat-dot-pink {
  background: var(--clay-stat-dot-pink);
}

.stat-dot-blue {
  background: var(--clay-stat-dot-blue);
}

.stat-dot-lavender {
  background: var(--clay-stat-dot-lavender);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--clay-text-primary);
}

.stat-label {
  font-size: var(--clay-font-sm);
  color: var(--clay-text-secondary);
}

/* Menu Container */
.menu-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 8rpx 40rpx;
  width: 750rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.menu-item {
  width: 670rpx;
  height: 136rpx;
  background: var(--clay-card-white);
  border-radius: var(--clay-radius-xxl);
  box-shadow: var(--clay-shadow-card-light);
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 0 32rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 28rpx;
  background: var(--clay-icon-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon text {
  font-size: 40rpx;
}

.menu-text-area {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-title {
  font-size: var(--clay-font-body);
  font-weight: 500;
  color: var(--clay-text-primary);
}

.menu-desc {
  font-size: var(--clay-font-sm);
  color: var(--clay-text-secondary);
}

.menu-arrow {
  font-size: 44rpx;
  color: var(--clay-text-muted);
  text-align: center;
  flex-shrink: 0;
  width: 44rpx;
}

/* ========== Developer Settings ========== */

.dev-divider {
  width: 670rpx;
  height: 2rpx;
  background: var(--clay-text-muted);
  opacity: 0.15;
  margin: 8rpx 0;
  flex-shrink: 0;
}

.dev-menu-item {
  opacity: 0.85;
}

.dev-icon {
  background: var(--clay-card-blue);
}

.dev-env-name {
  color: var(--clay-primary) !important;
  font-weight: 600 !important;
}

/* ========== Environment Picker Popup ========== */

.env-picker-container {
  background: var(--clay-card-white);
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.env-picker-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.env-picker-title {
  font-size: var(--clay-font-xxl);
  font-weight: 700;
  color: var(--clay-text-primary);
}

.env-picker-hint {
  font-size: var(--clay-font-sm);
  color: var(--clay-text-muted);
}

.env-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.env-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background: var(--clay-bg);
  box-shadow: var(--clay-shadow-card-light);
  transition: all 0.2s ease;
}

.env-item-active {
  background: var(--clay-icon-bg);
  box-shadow: 0px 0px 0px 3rpx var(--clay-primary);
}

.env-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.env-name {
  font-size: var(--clay-font-body);
  font-weight: 600;
  color: var(--clay-text-primary);
}

.env-desc {
  font-size: var(--clay-font-sm);
  color: var(--clay-text-secondary);
}

.env-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  border: 3rpx solid var(--clay-text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.env-check text {
  font-size: 28rpx;
  color: transparent;
}

.env-check-active {
  background: var(--clay-primary);
  border-color: var(--clay-primary);
}

.env-check-active text {
  color: #fff;
}

.env-picker-actions {
  display: flex;
  gap: 24rpx;
}

.env-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--clay-font-body);
  font-weight: 600;
}

.env-btn-cancel {
  background: var(--clay-bg);
  color: var(--clay-text-secondary);
  box-shadow: var(--clay-shadow-card-light);
}

.env-btn-confirm {
  background: var(--clay-primary);
  color: #fff;
  box-shadow: 0px 4px 12px 0px rgba(255, 168, 122, 0.4);
}

/* ========== Locale Picker Popup ========== */

.locale-picker-container {
  background: var(--clay-card-white);
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.locale-picker-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.locale-picker-title {
  font-size: var(--clay-font-xxl);
  font-weight: 700;
  color: var(--clay-text-primary);
}

.locale-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.locale-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  background: var(--clay-bg);
  box-shadow: var(--clay-shadow-card-light);
}

.locale-item-active {
  background: var(--clay-icon-bg);
  box-shadow: 0px 0px 0px 3rpx var(--clay-primary);
}

.locale-name {
  font-size: var(--clay-font-body);
  font-weight: 600;
  color: var(--clay-text-primary);
}

.locale-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  border: 3rpx solid var(--clay-text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.locale-check text {
  font-size: 28rpx;
  color: transparent;
}

.locale-check-active {
  background: var(--clay-primary);
  border-color: var(--clay-primary);
}

.locale-check-active text {
  color: #fff;
}

.locale-picker-actions {
  display: flex;
  justify-content: center;
}

.locale-btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--clay-font-body);
  font-weight: 600;
  padding: 0 80rpx;
}

.locale-btn-cancel {
  background: var(--clay-bg);
  color: var(--clay-text-secondary);
  box-shadow: var(--clay-shadow-card-light);
}