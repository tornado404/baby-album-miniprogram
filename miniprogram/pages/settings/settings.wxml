<view class="page page-settings" data-theme="{{themeAttr}}">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="settings-nav">
    <text class="nav-title-left">{{i18n.title || '我的'}}</text>
  </view>

  <!-- Content Area -->
  <scroll-view class="content-area" scroll-y enable-flex>

    <!-- User Card with badge entry -->
    <view class="user-card anim-scale-in" bindtap="goToAchievements" hover-class="user-card-hover">
      <view class="user-avatar {{userAvatar ? 'user-avatar-img-wrap' : ''}}">
        <image wx:if="{{userAvatar}}" src="{{userAvatar}}" mode="aspectFill" class="user-avatar-img"></image>
        <text wx:else>👩</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userName}}</text>
        <text class="user-record">{{recordDaysText}}</text>
      </view>
      <view class="badge-entry" wx:if="{{achievementCount > 0}}">
        <text class="badge-icon-text">🏆</text>
        <text class="badge-count-text">{{achievementCount}}</text>
      </view>
    </view>

    <!-- Stats Container (single card, 3 columns) -->
    <view class="stats-container anim-fade-in anim-delay-1">
      <view class="stat-item">
        <text class="stat-value">{{photoCount}}</text>
        <text class="stat-label">{{i18n.photos || '照片'}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{videoCount}}</text>
        <text class="stat-label">{{i18n.videos || '视频'}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{modelCount || 0}}</text>
        <text class="stat-label">{{i18n.models || '3D模型'}}</text>
      </view>
    </view>

    <!-- Menu Items -->
    <view class="menu-container anim-slide-up anim-delay-2">
      <view class="menu-item" bindtap="onMenuTap" data-key="baby_manage">        <view class="menu-icon">
          <text>👶</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">{{i18n.babyManage || '宝宝管理'}}</text>
          <text class="menu-desc">{{i18n.babyManageDesc || '管理宝宝档案'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="growth_compare">
        <view class="menu-icon">
          <text>📊</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">{{i18n.growthCompare || '成长对比'}}</text>
          <text class="menu-desc">{{i18n.growthCompareDesc || '照片前后对比'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="achievements">
        <view class="menu-icon">
          <text>🏆</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">{{i18n.achievements || '成就徽章'}}</text>
          <text class="menu-desc">{{i18n.achievementsDesc || '查看已获得的徽章'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="share">
        <view class="menu-icon">
          <text>🔗</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">{{i18n.share || '分享设置'}}</text>
          <text class="menu-desc">{{i18n.shareDesc || '家人共享设置'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onLocaleTap">
        <view class="menu-icon">
          <text>🌐</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">Language / 语言</text>
          <text class="menu-desc">{{currentLocale === 'zh-CN' ? '中文' : 'English'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="export_data">
        <view class="menu-icon">
          <text>📤</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">{{i18n.exportData || '导出数据'}}</text>
          <text class="menu-desc">{{i18n.exportDataDesc || '导出所有数据为 JSON'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="export_report">
        <view class="menu-icon">
          <text>📋</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">{{i18n.exportReport || '成长报告'}}</text>
          <text class="menu-desc">{{i18n.exportReportDesc || '生成宝宝成长报告'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="about">
        <view class="menu-icon">
          <text>ℹ️</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">{{i18n.about || '关于'}}</text>
          <text class="menu-desc">{{i18n.aboutDesc || '版本 1.0.0'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <!-- Divider -->
      <view class="dev-divider"></view>

      <!-- Developer Settings -->
      <view class="menu-item dev-menu-item" bindtap="onEnvSwitchTap">
        <view class="menu-icon dev-icon">
          <text>🛠</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">开发者设置</text>
          <text class="menu-desc dev-env-name">{{envName}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </scroll-view>

  <!-- Environment Picker Popup -->
  <t-popup visible="{{showEnvPicker}}" placement="bottom" bind:visible-change="onEnvPickerClose">
    <view class="env-picker-container">
      <view class="env-picker-header">
        <text class="env-picker-title">切换 API 环境</text>
        <text class="env-picker-hint">切换后需重启小程序生效</text>
      </view>
      <view class="env-list">
        <view
          class="env-item {{selectedEnv === item.key ? 'env-item-active' : ''}}"
          wx:for="{{environments}}"
          wx:key="key"
          data-env="{{item.key}}"
          bindtap="onEnvSelect"
        >
          <view class="env-info">
            <text class="env-name">{{item.name}}</text>
            <text class="env-desc">{{item.desc}}</text>
          </view>
          <view class="env-check {{selectedEnv === item.key ? 'env-check-active' : ''}}">
            <text wx:if="{{selectedEnv === item.key}}">✓</text>
          </view>
        </view>
      </view>
      <view class="env-picker-actions">
        <view class="env-btn env-btn-cancel" bindtap="onEnvPickerClose">取消</view>
        <view class="env-btn env-btn-confirm" bindtap="onConfirmSwitch">确认切换</view>
      </view>
    </view>
  </t-popup>

  <!-- Bottom Navigation -->
  <bottom-nav current="profile"></bottom-nav>

  <!-- Locale Picker Popup -->
  <t-popup visible="{{showLocalePicker}}" placement="bottom" bind:visible-change="onLocalePickerClose">
    <view class="locale-picker-container">
      <view class="locale-picker-header">
        <text class="locale-picker-title">Language / 语言</text>
      </view>
      <view class="locale-list">
        <view
          class="locale-item {{currentLocale === item.key ? 'locale-item-active' : ''}}"
          wx:for="{{availableLocales}}"
          wx:key="key"
          data-locale="{{item.key}}"
          bindtap="onLocaleSelect"
        >
          <text class="locale-name">{{item.name}}</text>
          <view class="locale-check {{currentLocale === item.key ? 'locale-check-active' : ''}}">
            <text wx:if="{{currentLocale === item.key}}">✓</text>
          </view>
        </view>
      </view>
      <view class="locale-picker-actions">
        <view class="locale-btn locale-btn-cancel" bindtap="onLocalePickerClose">取消</view>
      </view>
    </view>
  </t-popup>
</view>