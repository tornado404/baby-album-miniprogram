<view class="page page-settings">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="settings-nav">
    <text class="nav-title-centered">我的</text>
  </view>

  <!-- Content Area -->
  <scroll-view class="content-area" scroll-y enable-flex>

    <!-- User Card -->
    <view class="user-card">
      <view class="user-avatar">
        <text>👩</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userName}}</text>
        <text class="user-record">记录天数：{{recordDays}}天</text>
      </view>
      <view class="achievement-badge">
        <text class="badge-icon">🏆</text>
        <text class="badge-count">{{achievementCount}}</text>
      </view>
    </view>

    <!-- Stats Container -->
    <view class="stats-container">
      <view class="stat-item">
        <view class="stat-dot stat-dot-pink"></view>
        <text class="stat-value">{{photoCount}}</text>
        <text class="stat-label">照片</text>
      </view>
      <view class="stat-item">
        <view class="stat-dot stat-dot-blue"></view>
        <text class="stat-value">{{videoCount}}</text>
        <text class="stat-label">视频</text>
      </view>
      <view class="stat-item">
        <view class="stat-dot stat-dot-lavender"></view>
        <text class="stat-value">{{modelCount}}</text>
        <text class="stat-label">3D模型</text>
      </view>
    </view>

    <!-- Menu Items -->
    <view class="menu-container">
      <view class="menu-item" bindtap="onMenuTap" data-key="baby_manage">
        <view class="menu-icon">
          <text>👶</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">宝宝管理</text>
          <text class="menu-desc">管理宝宝档案</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="growth_compare">
        <view class="menu-icon">
          <text>📊</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">成长对比</text>
          <text class="menu-desc">照片前后对比</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="achievements">
        <view class="menu-icon">
          <text>🏆</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">成就徽章</text>
          <text class="menu-desc">查看已获得的徽章</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="storage">
        <view class="menu-icon">
          <text>💾</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">存储管理</text>
          <text class="menu-desc">管理本地和云端存储</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="share">
        <view class="menu-icon">
          <text>🔗</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">分享设置</text>
          <text class="menu-desc">家人共享设置</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="onMenuTap" data-key="about">
        <view class="menu-icon">
          <text>ℹ️</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">关于</text>
          <text class="menu-desc">版本 1.0.0</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <!-- Divider -->
      <view class="dev-divider"></view>

      <!-- Developer Settings -->
      <view class="menu-item dev-menu-item" bindtap="onEnvSwitchTap">
        <view class="menu-icon dev-icon">
          <text>🛠</text>
        </view>
        <view class="menu-text-area">
          <text class="menu-title">开发者设置</text>
          <text class="menu-desc dev-env-name">{{envName}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </scroll-view>

  <!-- Environment Picker Popup -->
  <t-popup visible="{{showEnvPicker}}" placement="bottom" bind:visible-change="onEnvPickerClose">
    <view class="env-picker-container">
      <view class="env-picker-header">
        <text class="env-picker-title">切换 API 环境</text>
        <text class="env-picker-hint">切换后需重启小程序生效</text>
      </view>
      <view class="env-list">
        <view
          class="env-item {{selectedEnv === item.key ? 'env-item-active' : ''}}"
          wx:for="{{environments}}"
          wx:key="key"
          data-env="{{item.key}}"
          bindtap="onEnvSelect"
        >
          <view class="env-info">
            <text class="env-name">{{item.name}}</text>
            <text class="env-desc">{{item.desc}}</text>
          </view>
          <view class="env-check {{selectedEnv === item.key ? 'env-check-active' : ''}}">
            <text wx:if="{{selectedEnv === item.key}}">✓</text>
          </view>
        </view>
      </view>
      <view class="env-picker-actions">
        <view class="env-btn env-btn-cancel" bindtap="onEnvPickerClose">取消</view>
        <view class="env-btn env-btn-confirm" bindtap="onConfirmSwitch">确认切换</view>
      </view>
    </view>
  </t-popup>

  <!-- Bottom Navigation -->
  <bottom-nav current="profile"></bottom-nav>
</view>