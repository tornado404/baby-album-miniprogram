<view class="page page-share-settings">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="share-nav">
    <view class="nav-back" bindtap="onBackTap">
      <text class="nav-back-arrow">←</text>
    </view>
    <text class="nav-title-centered">{{i18n.title || '分享设置'}}</text>
    <view class="nav-spacer"></view>
  </view>

  <!-- Content Area -->
  <scroll-view class="content-area" scroll-y enable-flex>

    <!-- Shared Relations List -->
    <view class="section-title">
      <text>共享列表</text>
    </view>

    <!-- Loading State -->
    <view wx:if="{{isLoading}}" class="loading-state">
      <text>加载中...</text>
    </view>

    <!-- Empty State -->
    <view wx:elif="{{shareList.length === 0}}" class="empty-state">
      <view class="empty-icon">
        <text>🔗</text>
      </view>
      <text class="empty-text">{{i18n.emptyList || '暂无共享关系'}}</text>
      <text class="empty-hint">{{i18n.emptyHint || '邀请家人一起记录宝宝成长'}}</text>
    </view>

    <!-- Share Relation Cards -->
    <view wx:else class="share-cards">
      <view wx:for="{{shareList}}" wx:key="id"
        class="share-card clay-card-{{item.cardColor || 'pink'}}">
        <view class="share-card-header">
          <view class="share-card-avatar">
            <text>👤</text>
          </view>
          <view class="share-card-info">
            <text class="share-card-name">{{item.viewerName || '家人'}}</text>
            <text class="share-card-perm">{{item.permission === 'editor' ? (i18n.editor || '可编辑') : (i18n.viewer || '仅查看')}}</text>
          </view>
        </view>
        <view class="share-card-body">
          <text class="share-card-baby">宝宝：{{item.babyName || '未知'}}</text>
          <text class="share-card-date">{{item.createdAt || ''}}</text>
        </view>
        <view class="share-card-actions">
          <view class="revoke-btn" data-id="{{item.id}}" bindtap="onRevokeTap">
            <text>{{i18n.revoke || '取消共享'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Invite Button -->
    <view class="invite-section">
      <view class="invite-btn" bindtap="onInviteTap">
        <text>{{i18n.inviteFamily || '邀请家人'}}</text>
      </view>
    </view>

  </scroll-view>

  <!-- Invite Popup -->
  <t-popup visible="{{showInvitePopup}}" placement="bottom" bind:visible-change="onInvitePopupClose">
    <view class="invite-popup-container">
      <view class="invite-popup-header">
        <text class="invite-popup-title">{{i18n.inviteFamily || '邀请家人'}}</text>
        <text class="invite-popup-hint">{{i18n.selectBaby || '选择宝宝'}}</text>
      </view>

      <!-- Baby Selection -->
      <view class="invite-section-label">
        <text>{{i18n.selectBaby || '选择宝宝'}}</text>
      </view>
      <view class="baby-options">
        <view wx:for="{{babies}}" wx:key="id"
          class="baby-option {{selectedBabyId === item.id ? 'baby-option-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onBabySelect">
          <text>{{item.name}}</text>
        </view>
      </view>

      <!-- Permission Selection -->
      <view class="invite-section-label">
        <text>{{i18n.permission || '权限'}}</text>
      </view>
      <view class="perm-options">
        <view class="perm-option {{selectedPermission === 'viewer' ? 'perm-option-active' : ''}}"
          data-perm="viewer" bindtap="onPermissionSelect">
          <text>{{i18n.viewer || '仅查看'}}</text>
        </view>
        <view class="perm-option {{selectedPermission === 'editor' ? 'perm-option-active' : ''}}"
          data-perm="editor" bindtap="onPermissionSelect">
          <text>{{i18n.editor || '可编辑'}}</text>
        </view>
      </view>

      <!-- Invite Token Display -->
      <view wx:if="{{inviteToken}}" class="token-display">
        <text class="token-label">{{i18n.inviteCode || '邀请码'}}</text>
        <view class="token-value-row">
          <text class="token-value">{{inviteToken}}</text>
          <view class="token-copy-btn" bindtap="onCopyToken">
            <text>{{i18n.copy || '复制'}}</text>
          </view>
        </view>
      </view>

      <!-- Actions -->
      <view class="invite-actions">
        <view class="invite-action-btn invite-action-cancel" bindtap="onInvitePopupClose">
          <text>{{i18n.cancel || '取消'}}</text>
        </view>
        <view class="invite-action-btn invite-action-confirm" bindtap="onCreateInvite">
          <text>{{i18n.createInvite || '生成邀请'}}</text>
        </view>
      </view>
    </view>
  </t-popup>

</view>
