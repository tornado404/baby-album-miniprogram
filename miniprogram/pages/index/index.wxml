<!-- index.wxml - 登录引导页（Onboarding） -->
<view class="page-onboarding">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Main Content: centered column -->
  <view class="onboarding-content">
    <!-- Spacer -->
    <view style="flex:1; min-height: 80rpx;"></view>

    <!-- Logo: big pink circle -->
    <view class="onboarding-logo">
      <text>👶</text>
    </view>

    <view style="height: 64rpx;"></view>

    <!-- App Name -->
    <text class="onboarding-title">宝宝成长相册</text>

    <view style="height: 24rpx;"></view>

    <!-- Welcome subtitle -->
    <text class="onboarding-subtitle">记录宝宝每一个成长瞬间</text>

    <view style="height: 16rpx;"></view>

    <!-- Feature tags -->
    <text class="onboarding-tags">照片 · 视频 · 3D模型 · 成长轨迹</text>

    <!-- Bottom section: button + privacy -->
    <view class="onboarding-bottom">
      <!-- Loading spinner (shown during auth) -->
      <view wx:if="{{authState === 'loading'}}" class="loading-container">
        <view class="loading-spinner"></view>
        <text class="loading-text">正在获取你的信息...</text>
      </view>

      <!-- Login button / Retry button -->
      <view wx:if="{{authState === 'idle' || authState === 'error'}}" class="login-btn" bindtap="onLoginTap">
        <text wx:if="{{authState === 'idle'}}" class="login-btn-text">微信一键登录</text>
        <text wx:elif="{{authState === 'error'}}" class="login-btn-text">重新授权</text>
      </view>

      <!-- Error message -->
      <text wx:if="{{authState === 'error'}}" class="error-text">{{errorMsg}}</text>

      <view style="height: 48rpx;"></view>

      <!-- Privacy policy -->
      <text class="privacy-text">登录即表示同意 用户协议 和 隐私政策</text>
    </view>
  </view>
</view>