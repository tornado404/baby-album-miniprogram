<view class="page page-agreement">

  <!-- Status Bar -->
  <view class="status-bar" style="height: {{safeTop}}px;"></view>

  <!-- Navigation Bar -->
  <view class="agreement-nav">
    <view class="nav-btn-circle" bindtap="onBack">
      <text>←</text>
    </view>
    <text class="nav-title">{{pageTitle}}</text>
    <view class="nav-spacer-right"></view>
  </view>

  <!-- Content Area -->
  <scroll-view class="content-area" scroll-y enable-flex>

    <!-- Header -->
    <view class="agreement-header anim-scale-in">
      <text class="agreement-title">{{pageTitle}}</text>
      <text class="agreement-updated">更新日期：{{updatedDate}}</text>
    </view>

    <!-- Sections -->
    <view
      class="agreement-section anim-fade-in"
      wx:for="{{contentSections}}"
      wx:for-index="sectionIdx"
      wx:key="title"
      style="animation-delay: {{sectionIdx * 50}}ms"
    >
      <text class="section-title">{{item.title}}</text>
      <text class="section-body">{{item.body}}</text>
    </view>

    <!-- Bottom Spacer -->
    <view style="height: 60rpx;"></view>
  </scroll-view>
</view>